<!DOCTYPE html>
<html lang="en" data-theme="<%= theme %>">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Cinzel:wght@400;500&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/tokens.css"/>
  <link rel="stylesheet" href="/css/nav.css"/>
  <link rel="stylesheet" href="/css/logo.css"/>
  <link rel="stylesheet" href="/css/footer.css"/>
  <link rel="stylesheet" href="/css/products.css"/>
  <link rel="stylesheet" href="/css/utilities.css"/>
  <link rel="stylesheet" href="/css/animations.css"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.4/gsap.min.js"></script>
  <style>
  /* Kill the green tint bleeding from --hero-bg on right side */
  .vault-header::before,
  .vault-header::after,
  .vault-header {
    background-color: #010d1f;
  }
  .vault-header {
    background-image:
      radial-gradient(ellipse at 50% 110%, rgba(0,160,255,.25) 0%, transparent 55%),
      radial-gradient(ellipse at 10% 60%,  rgba(0,80,200,.30)  0%, transparent 50%),
      radial-gradient(ellipse at 90% 50%,  rgba(0,100,220,.28) 0%, transparent 50%),
      radial-gradient(ellipse at 100% 80%, rgba(0,90,200,.35)  0%, transparent 45%),
      linear-gradient(180deg, #010d1f 0%, #021628 22%, #032238 50%, #021428 78%, #010c1c 100%);
  }


    position: relative; overflow: hidden;
    padding: clamp(100px,14vw,140px) 5% clamp(40px,5vw,60px);
    text-align: center;
    background:
      radial-gradient(ellipse at 50% 110%, rgba(0,160,255,.25) 0%, transparent 55%),
      radial-gradient(ellipse at 10% 60%,  rgba(0,80,200,.30)  0%, transparent 50%),
      radial-gradient(ellipse at 90% 40%,  rgba(0,120,220,.22) 0%, transparent 48%),
      radial-gradient(ellipse at 100% 100%, rgba(0,100,200,.20) 0%, transparent 40%),
      linear-gradient(180deg, #010d1f 0%, #021628 22%, #032238 50%, #021428 78%, #010c1c 100%);
  }
  .vault-header::before {
    content:''; position:absolute; inset:0; pointer-events:none;
    background:
      radial-gradient(ellipse 80% 45% at 28% 70%, rgba(0,110,220,.14) 0%, transparent 60%),
      radial-gradient(ellipse 55% 35% at 72% 28%, rgba(0,180,255,.09) 0%, transparent 55%);
    animation: oceanDrift 14s ease-in-out infinite;
  }
  .vault-header::after {
    content:''; position:absolute; inset:0; pointer-events:none;
    background:
      radial-gradient(ellipse 65% 50% at 62% 78%, rgba(0,70,180,.15) 0%, transparent 55%),
      radial-gradient(ellipse 45% 38% at 18% 38%, rgba(0,160,240,.10) 0%, transparent 50%);
    animation: oceanDrift 18s ease-in-out infinite reverse;
  }
  @keyframes oceanDrift {
    0%,100% { transform: translateX(0) scale(1); }
    40%     { transform: translateX(-6%) scale(1.03); }
    70%     { transform: translateX(5%) scale(.98); }
  }
  .vault-header-particles { position:absolute; inset:0; pointer-events:none; overflow:hidden; }
  .vh-p {
    position:absolute; border-radius:50%;
    animation: vhFloat var(--d,6s) ease-in-out infinite var(--dl,0s);
    opacity:0;
  }
  @keyframes vhFloat {
    0%,100%{transform:translateY(0) scale(1);opacity:0}
    20%{opacity:.7} 80%{opacity:.2}
    100%{transform:translateY(-90px) scale(.3);opacity:0}
  }
  .vault-header-glow {
    position:absolute; bottom:-1px; left:0; right:0; height:2px;
    background:linear-gradient(90deg,transparent,rgba(0,160,255,.7),rgba(0,200,255,1),rgba(0,160,255,.7),transparent);
    box-shadow:0 0 24px rgba(0,180,255,.5),0 0 60px rgba(0,120,220,.3);
  }
  .vault-header-inner { position:relative; z-index:2; max-width:600px; margin:0 auto; }
  .vault-header .section-badge {
    display:inline-block; padding:5px 18px; margin-bottom:1rem;
    border:1px solid rgba(0,180,255,.45); color:rgba(0,210,255,.85);
    background:rgba(0,130,200,.1); font-size:.6rem; letter-spacing:.35em; text-transform:uppercase;
  }
  .vault-title {
    font-family:'Cormorant Garamond',serif; font-size:clamp(2.2rem,6vw,4.8rem);
    font-weight:300; color:#dff0ff; margin:.4rem 0;
    text-shadow:0 0 60px rgba(0,160,255,.45),0 2px 30px rgba(0,0,0,.5);
  }
  .vault-subtitle {
    font-size:.72rem; letter-spacing:.3em; text-transform:uppercase;
    color:rgba(0,190,255,.6); margin-top:.4rem;
  }

  /* ══ LAYOUT — grid with sidebar ════════════════════════ */
  .vault-layout {
    display:flex; align-items:flex-start; gap:0;
    max-width:1500px; margin:0 auto; padding:0;
    position:relative;
  }

  /* ══ FILTER SIDEBAR ════════════════════════════════════ */
  .filter-sidebar {
    position:fixed; top:0; left:0;
    width:300px; height:100vh;
    overflow-y:auto; background:#040f1e;
    border-right:1px solid rgba(0,150,220,.2);
    z-index:1001;
    padding-top:68px;
    transform:translateX(-100%);
    transition:transform .4s cubic-bezier(.4,0,.2,1);
    scrollbar-width:thin; scrollbar-color:rgba(0,150,220,.3) transparent;
    box-shadow:4px 0 30px rgba(0,0,0,.5);
  }
  .filter-sidebar.open { transform:translateX(0); }

  /* Dim overlay behind sidebar */
  .filter-sidebar-overlay {
    display:none;
    position:fixed;
    top:0; left:0; right:0; bottom:0;
    width:100vw; height:100vh;
    background:rgba(0,0,0,.65);
    z-index:1000;
    cursor:pointer;
  }
  .filter-sidebar-overlay.show { display:block; }
  .filter-sidebar::-webkit-scrollbar { width:3px; }
  .filter-sidebar::-webkit-scrollbar-thumb { background:rgba(0,150,220,.35); }

  .sidebar-inner { padding:24px 20px; min-width:300px; }
  .sidebar-header {
    display:flex; justify-content:space-between; align-items:center;
    margin-bottom:20px; padding-bottom:14px;
    border-bottom:1px solid rgba(0,150,220,.2);
  }
  .sidebar-title {
    font-family:'Cinzel',serif; font-size:.82rem; letter-spacing:.18em;
    color:rgba(0,200,255,.9); text-transform:uppercase;
  }
  .sidebar-close {
    background:none; border:none; color:rgba(0,180,255,.5); cursor:pointer;
    font-size:1.1rem; line-height:1; transition:color .2s;
  }
  .sidebar-close:hover { color:rgba(0,200,255,.9); }

  /* Filter group */
  .sf-group { margin-bottom:20px; border-bottom:1px solid rgba(0,100,180,.12); padding-bottom:16px; }
  .sf-group:last-child { border-bottom:none; }
  .sf-group-header {
    display:flex; justify-content:space-between; align-items:center;
    cursor:pointer; padding:6px 0; user-select:none;
  }
  .sf-group-label {
    font-size:.65rem; letter-spacing:.22em; text-transform:uppercase;
    color:rgba(0,190,255,.75); font-weight:500;
  }
  .sf-group-arrow {
    font-size:.7rem; color:rgba(0,160,220,.5);
    transition:transform .25s; display:inline-block;
  }
  .sf-group.collapsed .sf-group-arrow { transform:rotate(-90deg); }
  .sf-group-body { margin-top:10px; }
  .sf-group.collapsed .sf-group-body { display:none; }

  /* Price range slider */
  .sf-price-track {
    position:relative; height:4px; background:rgba(0,100,180,.25);
    border-radius:2px; margin:16px 0 8px;
  }
  .sf-price-fill {
    position:absolute; height:100%; background:rgba(0,170,255,.7); border-radius:2px;
    box-shadow:0 0 8px rgba(0,160,255,.4);
  }
  .sf-price-thumb {
    position:absolute; top:50%; transform:translate(-50%,-50%);
    width:16px; height:16px; border-radius:50%;
    background:#0090e0; border:2px solid #00c8ff;
    box-shadow:0 0 10px rgba(0,180,255,.6); cursor:pointer;
    transition:box-shadow .2s;
  }
  .sf-price-thumb:hover { box-shadow:0 0 18px rgba(0,200,255,.8); }
  .sf-price-inputs { display:flex; gap:8px; align-items:center; margin-top:4px; }
  .sf-price-inputs input {
    flex:1; padding:6px 8px; background:rgba(0,80,160,.18);
    border:1px solid rgba(0,130,200,.3); color:#a0d4f0; font-size:.75rem;
    outline:none; text-align:center; border-radius:2px;
    transition:border-color .2s;
  }
  .sf-price-inputs input:focus { border-color:rgba(0,180,255,.6); }
  .sf-price-sep { color:rgba(0,160,220,.4); font-size:.8rem; }
  input[type=range].sf-range {
    width:100%; accent-color:#00aaff; cursor:pointer;
    background:transparent; height:4px;
  }

  /* Checkbox options */
  .sf-option {
    display:flex; align-items:center; justify-content:space-between;
    padding:7px 6px; cursor:pointer; border-radius:4px;
    transition:background .2s; user-select:none;
  }
  .sf-option:hover { background:rgba(0,120,200,.12); }
  .sf-option-left { display:flex; align-items:center; gap:10px; }
  .sf-option input[type=checkbox] { display:none; }
  .sf-checkbox {
    width:18px; height:18px; border:1.5px solid rgba(0,140,200,.4);
    border-radius:3px; display:flex; align-items:center; justify-content:center;
    flex-shrink:0; transition:all .2s; background:rgba(0,80,160,.1);
  }
  .sf-option input:checked ~ .sf-option-left .sf-checkbox,
  .sf-option.checked .sf-checkbox {
    background:rgba(0,160,255,.25); border-color:rgba(0,200,255,.8);
    box-shadow:0 0 8px rgba(0,180,255,.3);
  }
  .sf-checkbox-tick {
    width:10px; height:10px; opacity:0;
    background:url("data:image/svg+xml,%3Csvg viewBox='0 0 12 10' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 5l3 4L11 1' stroke='%2300c8ff' stroke-width='2' fill='none' stroke-linecap='round'/%3E%3C/svg%3E") center/contain no-repeat;
    transition:opacity .15s;
  }
  .sf-option.checked .sf-checkbox-tick { opacity:1; }
  .sf-option-label { font-size:.78rem; color:rgba(180,220,255,.75); }
  .sf-option-count { font-size:.62rem; color:rgba(0,150,200,.45); }

  /* Toggle switch */
  .sf-toggle-row {
    display:flex; align-items:center; justify-content:space-between;
    padding:8px 6px;
  }
  .sf-toggle-label { font-size:.78rem; color:rgba(180,220,255,.75); }
  .sf-toggle {
    width:38px; height:20px; background:rgba(0,80,160,.25);
    border:1px solid rgba(0,130,200,.35); border-radius:10px;
    position:relative; cursor:pointer; transition:background .25s, border-color .25s;
    flex-shrink:0;
  }
  .sf-toggle.on {
    background:rgba(0,160,255,.3); border-color:rgba(0,200,255,.7);
    box-shadow:0 0 10px rgba(0,180,255,.25);
  }
  .sf-toggle::after {
    content:''; position:absolute; top:2px; left:2px;
    width:14px; height:14px; border-radius:50%;
    background:rgba(0,140,200,.6); transition:transform .25s, background .25s;
  }
  .sf-toggle.on::after {
    transform:translateX(18px); background:#00c8ff;
    box-shadow:0 0 6px rgba(0,200,255,.7);
  }

  /* Sidebar apply/clear */
  .sf-actions { display:flex; gap:8px; margin-top:20px; }
  .sf-apply {
    flex:1; padding:10px; background:rgba(0,130,220,.35);
    border:1px solid rgba(0,180,255,.5); color:#00d0ff;
    font-size:.65rem; letter-spacing:.2em; text-transform:uppercase;
    cursor:pointer; transition:all .25s;
  }
  .sf-apply:hover { background:rgba(0,150,255,.5); box-shadow:0 0 16px rgba(0,180,255,.3); }
  .sf-clear {
    padding:10px 16px; background:transparent;
    border:1px solid rgba(0,100,160,.3); color:rgba(0,160,200,.5);
    font-size:.65rem; letter-spacing:.15em; text-transform:uppercase; cursor:pointer;
    transition:all .25s;
  }
  .sf-clear:hover { border-color:rgba(0,160,220,.5); color:rgba(0,200,255,.7); }

  /* ══ MAIN CONTENT ══════════════════════════════════════ */
  .vault-content { flex:1; min-width:0; }
  .vault-main { padding:40px 5% 100px; }

  /* ══ ACTIVE FILTER TAGS ════════════════════════════════ */
  .active-filters {
    display:flex; flex-wrap:wrap; gap:8px;
    padding:10px 5%; background:rgba(0,80,160,.06);
    border-bottom:1px solid rgba(0,100,180,.1);
  }
  .active-filters:empty { display:none; }
  .filter-tag {
    display:inline-flex; align-items:center; gap:6px;
    padding:4px 12px; background:rgba(0,130,220,.12);
    border:1px solid rgba(0,170,255,.3); color:rgba(0,200,255,.8);
    font-size:.62rem; letter-spacing:.1em; text-transform:uppercase;
    cursor:pointer; transition:all .2s; border-radius:2px;
  }
  .filter-tag:hover { background:rgba(0,160,255,.2); }
  .filter-tag-x { opacity:.6; font-size:.85rem; }

  /* Advanced button */
  .filter-btn-adv {
    padding:7px 16px; background:transparent;
    border:1px solid rgba(0,180,255,.35); color:rgba(0,210,255,.8);
    font-size:.62rem; letter-spacing:.15em; text-transform:uppercase;
    cursor:pointer; transition:all .25s; display:flex; align-items:center; gap:7px;
  }
  .filter-btn-adv:hover, .filter-btn-adv.active {
    background:rgba(0,180,255,.1); border-color:rgba(0,220,255,.6);
    box-shadow:0 0 14px rgba(0,180,255,.2);
  }
  .filter-btn-adv svg { width:12px; height:12px; }

  /* No results */
  .vault-no-results { display:none; text-align:center; padding:5rem 2rem; }
  .vault-no-results.show { display:block; }
  </style>
</head>
<body>
<%- include('css-base') %>
<%- include('nav') %>

<!-- ══ OCEAN HEADER ════════════════════════════════════════ -->
<header class="vault-header">
  <div class="vault-header-particles" id="vhParticles"></div>
  <div class="vault-header-glow"></div>
  <div class="vault-header-inner">
    <div class="section-badge">The Vault</div>
    <h1 class="vault-title">Our Full Collection</h1>
    <p class="vault-subtitle" id="vaultCount"><%= products.length %> pieces curated for you</p>
  </div>
</header>

<!-- ══ FILTER BAR ══════════════════════════════════════════ -->
<div class="filter-bar" id="filterBar">
  <div class="filter-bar-inner">
    <div class="filter-pills">
      <% const cats = [
        {val:'all',label:'All'},
        {val:'dream',label:'👑 Dream'},
        {val:'modest',label:'🌸 Modest'},
        {val:'aesthetic',label:'🤍 Aesthetic'},
        {val:'hijabs',label:'🕌 Hijabs'},
        {val:'accessories',label:'💍 Accessories'},
        {val:'perfumes',label:'🌹 Perfumes'}
      ]; %>
      <% cats.forEach(c => { %>
        <a href="/vault?category=<%= c.val==='all'?'':c.val %>&sort=<%= sort %>"
           class="filter-pill <%= activeCategory===c.val||(c.val==='all'&&activeCategory==='all')?'active':'' %>">
          <%= c.label %>
        </a>
      <% }); %>
    </div>
    <div class="filter-controls">
      <div class="filter-search-wrap">
        <form action="/vault" method="GET" class="filter-search-form">
          <input type="hidden" name="category" value="<%= activeCategory!=='all'?activeCategory:'' %>"/>
          <input type="text" name="search" id="vaultSearch" class="filter-search"
            placeholder="Search pieces..." value="<%= search %>" autocomplete="off"/>
          <button type="submit" class="filter-search-btn" aria-label="Search">🔍</button>
        </form>
        <div class="search-suggestions" id="searchSuggestions"></div>
      </div>
      <div class="sort-select-wrap">
        <select class="sort-select" onchange="doSort(this.value)">
          <option value="">Sort by</option>
          <option value="price-asc"  <%= sort==='price-asc' ?'selected':'' %>>Price: Low → High</option>
          <option value="price-desc" <%= sort==='price-desc'?'selected':'' %>>Price: High → Low</option>
          <option value="name-asc"   <%= sort==='name-asc'  ?'selected':'' %>>Name A → Z</option>
        </select>
      </div>
      <button class="filter-btn-adv" id="advBtn" onclick="toggleSidebar()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/>
          <line x1="11" y1="18" x2="13" y2="18"/>
        </svg>
        Filters
      </button>
    </div>
  </div>
  <!-- Active tags -->
  <div class="active-filters" id="activeFilterTags"></div>
</div>

<!-- Sidebar dim overlay -->
<div class="filter-sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

<!-- ══ FILTER SIDEBAR (fixed overlay) ════════════════════ -->
<div class="filter-sidebar" id="filterSidebar">
    <div class="sidebar-inner">
      <div class="sidebar-header">
        <span class="sidebar-title">✦ Filters</span>
        <button class="sidebar-close" onclick="toggleSidebar()">✕</button>
      </div>

      <!-- Price Range -->
      <div class="sf-group" id="sfg-price">
        <div class="sf-group-header" onclick="toggleGroup('sfg-price')">
          <span class="sf-group-label">Price Range</span>
          <span class="sf-group-arrow">▾</span>
        </div>
        <div class="sf-group-body">
          <div class="sf-price-track" id="priceTrack">
            <div class="sf-price-fill" id="priceFill"></div>
            <div class="sf-price-thumb" id="thumbMin" onmousedown="startDrag(event,'min')"></div>
            <div class="sf-price-thumb" id="thumbMax" onmousedown="startDrag(event,'max')"></div>
          </div>
          <div class="sf-price-inputs">
            <input type="number" id="afPriceMin" value="0"   min="0" max="10000" oninput="syncFromInputs()"/>
            <span class="sf-price-sep">—</span>
            <input type="number" id="afPriceMax" value="6000" min="0" max="10000" oninput="syncFromInputs()"/>
          </div>
        </div>
      </div>

      <!-- Size -->
      <div class="sf-group" id="sfg-size">
        <div class="sf-group-header" onclick="toggleGroup('sfg-size')">
          <span class="sf-group-label">Size</span>
          <span class="sf-group-arrow">▾</span>
        </div>
        <div class="sf-group-body">
          <% ['XS','S','M','L','XL','XXL','One Size'].forEach(sz => { %>
          <div class="sf-option" data-group="size" data-val="<%= sz %>" onclick="toggleOption(this)">
            <div class="sf-option-left">
              <div class="sf-checkbox"><div class="sf-checkbox-tick"></div></div>
              <span class="sf-option-label"><%= sz %></span>
            </div>
          </div>
          <% }); %>
        </div>
      </div>

      <!-- Material -->
      <div class="sf-group" id="sfg-material">
        <div class="sf-group-header" onclick="toggleGroup('sfg-material')">
          <span class="sf-group-label">Material</span>
          <span class="sf-group-arrow">▾</span>
        </div>
        <div class="sf-group-body">
          <% ['Silk','Chiffon','Crepe','Jersey','Linen','Velvet','Georgette','Satin'].forEach(m => { %>
          <div class="sf-option" data-group="material" data-val="<%= m %>" onclick="toggleOption(this)">
            <div class="sf-option-left">
              <div class="sf-checkbox"><div class="sf-checkbox-tick"></div></div>
              <span class="sf-option-label"><%= m %></span>
            </div>
          </div>
          <% }); %>
        </div>
      </div>

      <!-- Colour -->
      <div class="sf-group" id="sfg-color">
        <div class="sf-group-header" onclick="toggleGroup('sfg-color')">
          <span class="sf-group-label">Colour</span>
          <span class="sf-group-arrow">▾</span>
        </div>
        <div class="sf-group-body">
          <% [['Black','#1a1a1a'],['White','#f5f5f5'],['Navy','#1a2d5a'],['Blush','#e8b4b0'],
             ['Champagne','#f5deb3'],['Gold','#c5a059'],['Emerald','#1a6b45'],
             ['Plum','#5c1a5a'],['Sand','#c2a67d'],['Ivory','#fffff0']].forEach(([name,hex]) => { %>
          <div class="sf-option" data-group="color" data-val="<%= name %>" onclick="toggleOption(this)">
            <div class="sf-option-left">
              <div class="sf-checkbox"><div class="sf-checkbox-tick"></div></div>
              <span class="sf-option-label" style="display:flex;align-items:center;gap:8px">
                <span style="width:12px;height:12px;border-radius:50%;background:<%= hex %>;border:1px solid rgba(255,255,255,.2);flex-shrink:0"></span>
                <%= name %>
              </span>
            </div>
          </div>
          <% }); %>
        </div>
      </div>

      <!-- Availability toggles -->
      <div class="sf-group" id="sfg-avail">
        <div class="sf-group-header" onclick="toggleGroup('sfg-avail')">
          <span class="sf-group-label">Availability</span>
          <span class="sf-group-arrow">▾</span>
        </div>
        <div class="sf-group-body">
          <div class="sf-toggle-row">
            <span class="sf-toggle-label">In Stock Only</span>
            <div class="sf-toggle" id="tog-instock" onclick="toggleSwitch(this)"></div>
          </div>
          <div class="sf-toggle-row">
            <span class="sf-toggle-label">Featured Only</span>
            <div class="sf-toggle" id="tog-featured" onclick="toggleSwitch(this)"></div>
          </div>
          <div class="sf-toggle-row">
            <span class="sf-toggle-label">On Sale / Discount</span>
            <div class="sf-toggle" id="tog-sale" onclick="toggleSwitch(this)"></div>
          </div>
        </div>
      </div>

      <!-- Rating -->
      <div class="sf-group" id="sfg-rating">
        <div class="sf-group-header" onclick="toggleGroup('sfg-rating')">
          <span class="sf-group-label">Rating</span>
          <span class="sf-group-arrow">▾</span>
        </div>
        <div class="sf-group-body">
          <div class="sf-option" data-group="rating" data-val="4" onclick="toggleOption(this)">
            <div class="sf-option-left">
              <div class="sf-checkbox"><div class="sf-checkbox-tick"></div></div>
              <span class="sf-option-label">★★★★ 4 &amp; above</span>
            </div>
          </div>
          <div class="sf-option" data-group="rating" data-val="3" onclick="toggleOption(this)">
            <div class="sf-option-left">
              <div class="sf-checkbox"><div class="sf-checkbox-tick"></div></div>
              <span class="sf-option-label">★★★ 3 &amp; above</span>
            </div>
          </div>
        </div>
      </div>

      <div class="sf-actions">
        <button class="sf-apply" onclick="applyFilters()">Apply Filters</button>
        <button class="sf-clear" onclick="clearFilters()">Clear</button>
      </div>
    </div>
  </div>

  <!-- ══ PRODUCTS ════════════════════════════════════════ -->
  <main class="vault-main">
      <% if (products && products.length > 0) { %>
        <div class="products-grid" id="productsGrid">
          <% products.forEach(function(p){ %>
            <%- include('product-card', { p }) %>
          <% }); %>
        </div>
        <div class="vault-no-results" id="noResults">
          <span style="font-size:2.5rem;opacity:.2">✦</span>
          <h3 style="font-family:'Cormorant Garamond',serif;font-weight:300;color:var(--t2);margin:.8rem 0;font-size:1.5rem">No pieces match your filters</h3>
          <p style="font-size:.82rem;color:var(--t3)"><a href="#" onclick="clearFilters();return false" style="color:rgba(0,200,255,.7)">Clear all filters →</a></p>
        </div>
      <% } else { %>
        <div class="empty-state">
          <span>✦</span><h3>No pieces found</h3>
          <p><a href="/vault">Clear filters →</a></p>
        </div>
      <% } %>
    </main>

<%- include('js-core') %>
<%- include('footer') %>
<%- include('toast') %>
<%- include('cart-drawer') %>

<script>
// ── Ocean particles ─────────────────────────────────────
(function(){
  const c=document.getElementById('vhParticles'); if(!c) return;
  for(let i=0;i<24;i++){
    const p=document.createElement('div'); p.className='vh-p';
    const sz=Math.random()*3+1;
    const blue=Math.random()>.45;
    p.style.cssText=`width:${sz}px;height:${sz}px;left:${Math.random()*100}%;top:${Math.random()*100}%;--d:${4+Math.random()*9}s;--dl:${Math.random()*7}s;background:rgba(${blue?'0,180,255':'0,120,220'},${.4+Math.random()*.5});`;
    c.appendChild(p);
  }
})();

// ── Sort ─────────────────────────────────────────────────
function doSort(val){const u=new URL(window.location.href);u.searchParams.set('sort',val);window.location.href=u.toString();}

// ── Sticky bar ───────────────────────────────────────────
const bar=document.getElementById('filterBar');
window.addEventListener('scroll',()=>bar.classList.toggle('stuck',window.scrollY>200),{passive:true});

// ── Sidebar toggle ───────────────────────────────────────
function toggleSidebar(){
  const s=document.getElementById('filterSidebar');
  const b=document.getElementById('advBtn');
  const o=document.getElementById('sidebarOverlay');
  s.classList.toggle('open');
  b.classList.toggle('active');
  o.classList.toggle('show');
}

// ── Collapsible groups ───────────────────────────────────
function toggleGroup(id){document.getElementById(id).classList.toggle('collapsed');}

// ── Checkbox options ─────────────────────────────────────
function toggleOption(el){el.classList.toggle('checked');}

// ── Toggle switches ──────────────────────────────────────
function toggleSwitch(el){el.classList.toggle('on');}

// ── Price range slider ───────────────────────────────────
const PRICE_MAX=6000;
let priceMin=0, priceMax=PRICE_MAX;

function updatePriceUI(){
  const track=document.getElementById('priceTrack');
  if(!track) return;
  const w=track.offsetWidth;
  const minPct=priceMin/PRICE_MAX*100;
  const maxPct=priceMax/PRICE_MAX*100;
  document.getElementById('priceFill').style.left=minPct+'%';
  document.getElementById('priceFill').style.width=(maxPct-minPct)+'%';
  document.getElementById('thumbMin').style.left=minPct+'%';
  document.getElementById('thumbMax').style.left=maxPct+'%';
  document.getElementById('afPriceMin').value=priceMin;
  document.getElementById('afPriceMax').value=priceMax;
}

function syncFromInputs(){
  priceMin=Math.max(0,parseInt(document.getElementById('afPriceMin').value)||0);
  priceMax=Math.min(PRICE_MAX,parseInt(document.getElementById('afPriceMax').value)||PRICE_MAX);
  if(priceMin>priceMax) priceMin=priceMax;
  updatePriceUI();
}

let dragging=null;
function startDrag(e,which){
  dragging=which; e.preventDefault();
  document.addEventListener('mousemove',onDrag);
  document.addEventListener('mouseup',stopDrag);
  // Touch
  document.addEventListener('touchmove',onDragTouch,{passive:false});
  document.addEventListener('touchend',stopDrag);
}
function getDragPct(e){
  const track=document.getElementById('priceTrack');
  const rect=track.getBoundingClientRect();
  return Math.max(0,Math.min(1,(e.clientX-rect.left)/rect.width));
}
function onDrag(e){
  if(!dragging) return;
  const pct=getDragPct(e);
  const val=Math.round(pct*PRICE_MAX/50)*50;
  if(dragging==='min'){priceMin=Math.min(val,priceMax-50);}
  else {priceMax=Math.max(val,priceMin+50);}
  updatePriceUI();
}
function onDragTouch(e){
  if(!dragging||!e.touches[0]) return;
  onDrag(e.touches[0]);
}
function stopDrag(){
  dragging=null;
  document.removeEventListener('mousemove',onDrag);
  document.removeEventListener('mouseup',stopDrag);
  document.removeEventListener('touchmove',onDragTouch);
  document.removeEventListener('touchend',stopDrag);
}
// Init price UI after layout
window.addEventListener('load',updatePriceUI);

// ── Apply filters ────────────────────────────────────────
function applyFilters(){
  const cards=document.querySelectorAll('#productsGrid .product-card');
  const minP=priceMin, maxP=priceMax;
  const sizes=[...document.querySelectorAll('.sf-option[data-group=size].checked')].map(o=>o.dataset.val.toLowerCase());
  const mats=[...document.querySelectorAll('.sf-option[data-group=material].checked')].map(o=>o.dataset.val.toLowerCase());
  const cols=[...document.querySelectorAll('.sf-option[data-group=color].checked')].map(o=>o.dataset.val.toLowerCase());
  const inStock=document.getElementById('tog-instock').classList.contains('on');
  const featured=document.getElementById('tog-featured').classList.contains('on');
  const onSale=document.getElementById('tog-sale').classList.contains('on');

  let visible=0;
  cards.forEach(card=>{
    const priceEl=card.querySelector('.product-card-price');
    const price=priceEl?parseFloat(priceEl.textContent.replace(/[^0-9.]/g,'')):0;
    const name=(card.querySelector('.product-card-name')?.textContent||'').toLowerCase();
    const d=card.dataset;
    let show=true;

    if(price<minP||price>maxP) show=false;
    if(show&&sizes.length){const cs=(d.sizes||'').toLowerCase();if(!sizes.some(s=>cs.includes(s)))show=false;}
    if(show&&mats.length){const cm=(d.material||name).toLowerCase();if(!mats.some(m=>cm.includes(m)))show=false;}
    if(show&&cols.length){const cc=(d.colors||name).toLowerCase();if(!cols.some(c=>cc.includes(c)))show=false;}
    if(show&&inStock&&card.querySelector('.sold-out-label'))show=false;
    if(show&&featured&&!card.querySelector('[class*="featured"]'))show=false;
    if(show&&onSale&&!card.querySelector('[class*="discount"],[class*="sale"]'))show=false;

    card.style.display=show?'':'none';
    if(show)visible++;
  });

  document.getElementById('vaultCount').textContent=`${visible} pieces curated for you`;
  document.getElementById('noResults').classList.toggle('show',visible===0);
  buildTags({minP,maxP,sizes,mats,cols,inStock,featured,onSale});
}

// ── Build active tags ────────────────────────────────────
function buildTags({minP,maxP,sizes,mats,cols,inStock,featured,onSale}){
  const ct=document.getElementById('activeFilterTags'); ct.innerHTML='';
  const add=(label,fn)=>{
    const t=document.createElement('span'); t.className='filter-tag';
    t.innerHTML=`${label} <span class="filter-tag-x">✕</span>`; t.onclick=fn; ct.appendChild(t);
  };
  if(minP>0||maxP<PRICE_MAX) add(`R${minP}–R${maxP}`,()=>{priceMin=0;priceMax=PRICE_MAX;updatePriceUI();applyFilters();});
  sizes.forEach(s=>add(`Size: ${s.toUpperCase()}`,()=>{
    document.querySelectorAll('.sf-option[data-group=size]').forEach(o=>{
      if(o.dataset.val.toLowerCase()===s.toLowerCase()) o.classList.remove('checked');
    });
    applyFilters();
  }));
  mats.forEach(m=>add(`Material: ${m}`,()=>{
    document.querySelectorAll('.sf-option[data-group=material]').forEach(o=>{
      if(o.dataset.val.toLowerCase()===m.toLowerCase()) o.classList.remove('checked');
    });
    applyFilters();
  }));
  cols.forEach(c=>add(`Colour: ${c}`,()=>{
    // data-val is stored with original case, find case-insensitively
    document.querySelectorAll('.sf-option[data-group=color]').forEach(o=>{
      if(o.dataset.val.toLowerCase()===c.toLowerCase()) o.classList.remove('checked');
    });
    applyFilters();
  }));
  if(inStock) add('In Stock',()=>{document.getElementById('tog-instock').classList.remove('on');applyFilters();});
  if(featured) add('Featured',()=>{document.getElementById('tog-featured').classList.remove('on');applyFilters();});
  if(onSale)  add('On Sale',()=>{document.getElementById('tog-sale').classList.remove('on');applyFilters();});
}

// ── Clear all ────────────────────────────────────────────
function clearFilters(){
  document.querySelectorAll('.sf-option.checked').forEach(o=>o.classList.remove('checked'));
  document.querySelectorAll('.sf-toggle.on').forEach(t=>t.classList.remove('on'));
  priceMin=0; priceMax=PRICE_MAX; updatePriceUI();
  document.querySelectorAll('#productsGrid .product-card').forEach(c=>c.style.display='');
  document.getElementById('activeFilterTags').innerHTML='';
  document.getElementById('noResults').classList.remove('show');
  document.getElementById('vaultCount').textContent='<%= products.length %> pieces curated for you';
}

// ── GSAP entrance ────────────────────────────────────────
if(typeof gsap!=='undefined'){
  gsap.from('.product-card',{opacity:0,y:28,duration:.55,stagger:.05,ease:'power3.out',delay:.2});
}
</script>
</body>
</html>
