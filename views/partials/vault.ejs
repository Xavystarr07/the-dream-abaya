<script>


(function(){
  const c=document.getElementById('vhParticles'); if(!c) return;
  for(let i=0;i<24;i++){
    const p=document.createElement('div'); p.className='vh-p';
    const sz=Math.random()*3+1;
    const blue=Math.random()>.45;
    p.style.cssText=`width:${sz}px;height:${sz}px;left:${Math.random()*100}%;top:${Math.random()*100}%;--d:${4+Math.random()*9}s;--dl:${Math.random()*7}s;background:rgba(${blue?'0,180,255':'0,120,220'},${.4+Math.random()*.5});`;
    c.appendChild(p);
  }
})();

function doSort(val){const u=new URL(window.location.href);u.searchParams.set('sort',val);window.location.href=u.toString();}
function toggleSidebar(){
  document.getElementById('filterSidebar').classList.toggle('open');
  document.getElementById('advBtn').classList.toggle('active');
  document.getElementById('sidebarOverlay').classList.toggle('show');
}
function toggleGroup(id){document.getElementById(id).classList.toggle('collapsed');}
function toggleOption(el){el.classList.toggle('checked');}
function toggleSwitch(el){el.classList.toggle('on');}

const PRICE_MAX=10000;
let priceMin=0, priceMax=6000;

function updatePriceUI(){
  const track=document.getElementById('priceTrack'); if(!track) return;
  const minPct=priceMin/PRICE_MAX*100;
  const maxPct=priceMax/PRICE_MAX*100;
  document.getElementById('priceFill').style.left=minPct+'%';
  document.getElementById('priceFill').style.width=(maxPct-minPct)+'%';
  document.getElementById('thumbMin').style.left=minPct+'%';
  document.getElementById('thumbMax').style.left=maxPct+'%';
  document.getElementById('afPriceMin').value=priceMin;
  document.getElementById('afPriceMax').value=priceMax;
}

function syncFromInputs(){
  priceMin=Math.max(0,parseInt(document.getElementById('afPriceMin').value)||0);
  priceMax=Math.min(PRICE_MAX,parseInt(document.getElementById('afPriceMax').value)||PRICE_MAX);
  if(priceMin>priceMax) priceMin=priceMax;
  updatePriceUI();
}

let dragging=null;
function startDrag(e,which){
  dragging=which; e.preventDefault();
  document.addEventListener('mousemove',onDrag);
  document.addEventListener('mouseup',stopDrag);
}
function onDrag(e){
  if(!dragging) return;
  const track=document.getElementById('priceTrack');
  const rect=track.getBoundingClientRect();
  const pct=Math.max(0,Math.min(1,(e.clientX-rect.left)/rect.width));
  const val=Math.round(pct*PRICE_MAX/50)*50;
  if(dragging==='min'){priceMin=Math.min(val,priceMax-50);}
  else {priceMax=Math.max(val,priceMin+50);}
  updatePriceUI();
}
function stopDrag(){
  dragging=null;
  document.removeEventListener('mousemove',onDrag);
  document.removeEventListener('mouseup',stopDrag);
}

function applyFilters(){
  const cards=document.querySelectorAll('#productsGrid .product-card');
  const minP=priceMin, maxP=priceMax;
  const sizes=[...document.querySelectorAll('.sf-option[data-group=size].checked')].map(o=>o.dataset.val.toLowerCase());
  const mats=[...document.querySelectorAll('.sf-option[data-group=material].checked')].map(o=>o.dataset.val.toLowerCase());
  const cols=[...document.querySelectorAll('.sf-option[data-group=color].checked')].map(o=>o.dataset.val.toLowerCase());
  const inStock=document.getElementById('tog-instock').classList.contains('on');
  const featured=document.getElementById('tog-featured').classList.contains('on');
  const onSale=document.getElementById('tog-sale').classList.contains('on');

  let visible=0;
  cards.forEach(card=>{
    const priceEl=card.querySelector('.product-card-price');
    const price=priceEl?parseFloat(priceEl.textContent.replace(/[^0-9.]/g,'')):0;
    const d=card.dataset;
    let show=true;

    if(price<minP||price>maxP) show=false;
    if(show&&sizes.length){const cs=(d.sizes||'').toLowerCase();if(!sizes.some(s=>cs.includes(s)))show=false;}
    if(show&&mats.length){const cm=(d.material||'').toLowerCase();if(!mats.some(m=>cm.includes(m)))show=false;}
    if(show&&cols.length){const cc=(d.colors||'').toLowerCase();if(!cols.some(c=>cc.includes(c)))show=false;}
    if(show&&inStock&&card.querySelector('.sold-out-label'))show=false;
    if(show&&featured&&!card.dataset.featured)show=false;

    card.style.display=show?'':'none';
    if(show)visible++;
  });

  document.getElementById('vaultCount').textContent=`${visible} pieces curated for you`;
  document.getElementById('noResults').classList.toggle('show',visible===0);
  toggleSidebar();
}

function clearFilters(){
  document.querySelectorAll('.sf-option.checked').forEach(o=>o.classList.remove('checked'));
  document.querySelectorAll('.sf-toggle.on').forEach(t=>t.classList.remove('on'));
  priceMin=0; priceMax=6000; updatePriceUI();
  document.querySelectorAll('#productsGrid .product-card').forEach(c=>c.style.display='');
  document.getElementById('noResults').classList.remove('show');
  document.getElementById('vaultCount').textContent='<%= products.length %> pieces curated for you';
}

window.addEventListener('load',updatePriceUI);
</script>
<script>
/* ══════════════════════════════════════════════════════════
   VAULT RIPPLE WATER ENGINE
   Physics-based 2D ripple simulation — matches CodePen effect
   ══════════════════════════════════════════════════════════ */
(function() {
  const header  = document.getElementById('vaultRippleHeader');
  const canvas  = document.getElementById('vault-ripple-canvas');
  if (!header || !canvas) return;

  const ctx     = canvas.getContext('2d');

  /* ── CONFIG ─────────────────────────────────────────────── */
  const DAMPING   = 0.985;  // How long ripples last (0.98=longer, 0.97=shorter)
  const DISTURB_R = 5;      // Radius of each ripple drop (px at full res)
  const SCALE     = 2;      // Simulation resolution divisor (2=half res, faster)

  /* ── STATE ──────────────────────────────────────────────── */
  let W, H, simW, simH;
  let current, previous;    // Two ripple height buffers (ping-pong)
  let imageData, pixels;    // Canvas pixel buffer

  /* ── BACKGROUND COLOURS (deep water palette) ────────────── */
  // These blend between shallow and deep water based on ripple height
  // Matches the dark ocean blue of vault-header
const COLOUR_DEEP    = { r: 8,  g: 20, b: 45  };   // slightly lighter navy base
const COLOUR_SHALLOW = { r: 160, g: 210, b: 255 };  // #A0D2FF — soft periwinkle-blue (not cyan)
const COLOUR_CREST   = { r: 230, g: 245, b: 255 };  // #E6F5FF — near-white ice crest

  /* ── INIT ────────────────────────────────────────────────── */
  function init() {
    W    = header.offsetWidth;
    H    = header.offsetHeight;
    simW = Math.floor(W / SCALE);
    simH = Math.floor(H / SCALE);

    canvas.width  = W;
    canvas.height = H;

    /* Flat Float32 arrays for ripple physics — two buffers */
    current  = new Float32Array(simW * simH);
    previous = new Float32Array(simW * simH);

    /* ImageData for direct pixel writes */
    imageData = ctx.createImageData(W, H);
    pixels    = imageData.data;

    /* Fill alpha channel once (always 255) */
    for (let i = 3; i < pixels.length; i += 4) pixels[i] = 255;
  }

  /* ── DISTURB: create a ripple at simulation coords ────────── */
  function disturb(sx, sy, strength) {
    // sx/sy are canvas px → convert to sim coords
    const cx = Math.floor(sx / SCALE);
    const cy = Math.floor(sy / SCALE);
    const r  = Math.ceil(DISTURB_R);

    for (let dy = -r; dy <= r; dy++) {
      for (let dx = -r; dx <= r; dx++) {
        if (dx * dx + dy * dy <= r * r) {
          const nx = cx + dx;
          const ny = cy + dy;
          if (nx > 0 && nx < simW - 1 && ny > 0 && ny < simH - 1) {
            // Height is negative (drops below surface) then springs up
            previous[ny * simW + nx] = -strength;
          }
        }
      }
    }
  }

  /* ── PHYSICS STEP ────────────────────────────────────────── */
  function step() {
    for (let y = 1; y < simH - 1; y++) {
      for (let x = 1; x < simW - 1; x++) {
        const i = y * simW + x;

        /* Wave equation: average of 4 neighbours × 2 − previous − dampen */
        current[i] = (
          previous[i - 1] +
          previous[i + 1] +
          previous[i - simW] +
          previous[i + simW]
        ) / 2 - current[i];

        current[i] *= DAMPING;
      }
    }

    /* Swap buffers */
    const temp = previous;
    previous   = current;
    current    = temp;
  }

  /* ── RENDER: write pixels from height field ──────────────── */
  function render() {
    for (let y = 0; y < H; y++) {
      const sy = Math.floor(y / SCALE);

      for (let x = 0; x < W; x++) {
        const sx = Math.floor(x / SCALE);
        const h  = previous[sy * simW + sx]; // height value -255..255

        /* Map height to colour */
        // h < 0 = trough (dark), h > 0 = crest (bright)
        let r, g, b;
        const norm = Math.max(-1, Math.min(1, h / 120)); // Normalise

        if (norm >= 0) {
          /* Crest: deep → crest white */
          r = COLOUR_DEEP.r + (COLOUR_CREST.r - COLOUR_DEEP.r) * norm;
          g = COLOUR_DEEP.g + (COLOUR_CREST.g - COLOUR_DEEP.g) * norm;
          b = COLOUR_DEEP.b + (COLOUR_CREST.b - COLOUR_DEEP.b) * norm;
        } else {
          /* Trough: deep → shallow blue */
          const t = -norm;
          r = COLOUR_DEEP.r + (COLOUR_SHALLOW.r - COLOUR_DEEP.r) * t * 0.4;
          g = COLOUR_DEEP.g + (COLOUR_SHALLOW.g - COLOUR_DEEP.g) * t * 0.4;
          b = COLOUR_DEEP.b + (COLOUR_SHALLOW.b - COLOUR_DEEP.b) * t * 0.4;
        }

        const pi = (y * W + x) * 4;
        pixels[pi]     = r | 0;
        pixels[pi + 1] = g | 0;
        pixels[pi + 2] = b | 0;
        /* alpha already set to 255 */
      }
    }

    ctx.putImageData(imageData, 0, 0);
  }

  /* ── MOUSE HANDLER ───────────────────────────────────────── */
  let lastMx = -1, lastMy = -1;

header.addEventListener('mousemove', function(e) {
    const rect = header.getBoundingClientRect();
    const mx   = e.clientX - rect.left;
    const my   = e.clientY - rect.top;

    /* Only disturb if mouse moved enough (avoids micro-jitter floods) */
    const dist = Math.hypot(mx - lastMx, my - lastMy);
    if (dist > 4) {
      // Added by Gemini: Call the disturb function to actually create the ripple
      disturb(mx, my, 150); 
      lastMx = mx;
      lastMy = my;
    }
  });

  /* Touch support */
  header.addEventListener('touchmove', function(e) {
    e.preventDefault();
    const rect  = header.getBoundingClientRect();
    const touch = e.touches[0];
    disturb(touch.clientX - rect.left, touch.clientY - rect.top, 200);
  }, { passive: false });

  /* ── AUTO DROPS: ambient ripples when idle ───────────────── */
  function autoRipple() {
    const x = Math.random() * W;
    const y = Math.random() * H;
    disturb(x, y, 30 + Math.random() * 50); /* Gentle ambient drops */
    /* Schedule next drop: 800–2500ms */
    setTimeout(autoRipple, 800 + Math.random() * 1700);
  }

  /* ── ANIMATION LOOP ──────────────────────────────────────── */
  function loop() {
    step();
    render();
    requestAnimationFrame(loop);
  }

  /* ── RESIZE ──────────────────────────────────────────────── */
  let resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(init, 250);
  });

  /* ── BOOT ────────────────────────────────────────────────── */
  init();
  autoRipple();      /* Start ambient drops */
  loop();            /* Start physics+render loop */

})();
</script>
</body>
</html>