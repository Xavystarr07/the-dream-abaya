<!-- ══ MIST REVEAL ══════════════════════════════════════════ -->
<div id="reveal-overlay" aria-hidden="true">

  <!-- Particle mist canvas — JS draws drifting gold/purple motes -->
  <canvas id="mistCanvas" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:2"></canvas>

  <!-- Mist layers — CSS animated fog panels -->
  <div class="mist-layer mist-1"></div>
  <div class="mist-layer mist-2"></div>
  <div class="mist-layer mist-3"></div>
  <div class="mist-layer mist-4"></div>

  <!-- Radial glow behind text -->
  <div class="mist-glow"></div>

  <!-- Branding text — same IDs as before so JS still targets them -->
  <div id="reveal-text" style="opacity:1">
    <div class="reveal-ornament">✦ &nbsp; ✦ &nbsp; ✦</div>
    <div class="reveal-tagline">AWAKEN THE PRINCESS WITHIN</div>
    <div class="reveal-brand">The Dream Abaya</div>
    <div class="reveal-loading"><div class="reveal-loading-bar"></div></div>
  </div>

</div>
