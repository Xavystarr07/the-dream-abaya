<div id="reveal-overlay">
    <div id="reveal-text">
        <div class="reveal-animation-container">
            <img src="/images/reveal/princess.png" alt="Princess" class="princess-drawing">
        </div>
        
        <div class="reveal-tagline">Awaken the Princess Within</div>
        
        <div class="reveal-loading-area">
            <div class="reveal-loading-container">
                <div class="reveal-loading-bar" id="revealBar">
                    <div class="bar-glow"></div> </div>
            </div>
            <div class="reveal-brand">The Dream Abaya</div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const bar = document.getElementById('revealBar');
        const overlay = document.getElementById('reveal-overlay');
        let width = 0;

        const loadingInterval = setInterval(() => {
            if (width >= 100) {
                clearInterval(loadingInterval);
                setTimeout(() => {
                    overlay.classList.add('hidden-overlay');
                    setTimeout(() => { overlay.style.display = 'none'; }, 1000);
                }, 600);
            } else {
                // Slower, more deliberate "premium" loading speed
                width += Math.random() * 0.8; 
                if (width > 100) width = 100;
                bar.style.width = width + '%';
            }
        }, 15); // Smoother update frequency
    });
</script>