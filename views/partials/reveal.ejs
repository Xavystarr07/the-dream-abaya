<div id="reveal-overlay">
    <div id="reveal-text">
        <div class="reveal-animation-container">
            <img src="/images/reveal/princess.png" alt="Princess" class="princess-drawing">
        </div>
        
        <div id="brandName" class="reveal-brand">The Dream Abaya</div>

        <div id="fadeGroupFirst" class="first-fade-group">
            <div class="reveal-tagline">Awaken the Princess Within</div>
            <div class="reveal-loading-area">
                <div class="reveal-loading-container">
                    <div id="revealBar" class="reveal-loading-bar"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        const bar = document.getElementById('revealBar');
        const overlay = document.getElementById('reveal-overlay');
        const fadeGroupFirst = document.getElementById('fadeGroupFirst');
        let progress = 0;

        const interval = setInterval(() => {
            // Your preferred speed (80ms interval)
            progress += Math.random() * 8 + 4; 

            if (progress >= 100) {
                progress = 100;
                bar.style.width = '100%';
                clearInterval(interval);
                
                // STAGE 1: Tagline and Loading Bar disappear quickly (1.2s)
                setTimeout(() => {
                    fadeGroupFirst.classList.add('element-hidden');
                    
                    // STAGE 2: THE MAGICAL DISSOLVE
                    // Princess and Brand stay alone for 1.2s then fade beautifully
                    setTimeout(() => {
                        overlay.classList.add('magical-fade-out');
                        
                        setTimeout(() => {
                            overlay.style.display = 'none';
                        }, 4000); // Matches the 4s cinematic fade
                    }, 1200); 
                }, 500);
            } else {
                bar.style.width = progress + '%';
            }
        }, 80); 
    })();
</script>