<!-- ══ ROYAL CURTAIN REVEAL ══════════════════════════════════ -->
<div id="reveal-overlay" aria-hidden="true">
  <!-- Gold pelmet at top -->
  <div class="curtain-pelmet">
    <div class="pelmet-edge"></div>
    <div class="pelmet-tassels">
      <span class="pelmet-tassel"></span><span class="pelmet-tassel"></span>
      <span class="pelmet-tassel"></span><span class="pelmet-tassel"></span>
      <span class="pelmet-tassel"></span><span class="pelmet-tassel"></span>
      <span class="pelmet-tassel"></span><span class="pelmet-tassel"></span>
      <span class="pelmet-tassel"></span><span class="pelmet-tassel"></span>
      <span class="pelmet-tassel"></span><span class="pelmet-tassel"></span>
      <span class="pelmet-tassel"></span><span class="pelmet-tassel"></span>
      <span class="pelmet-tassel"></span><span class="pelmet-tassel"></span>
      <span class="pelmet-tassel"></span><span class="pelmet-tassel"></span>
      <span class="pelmet-tassel"></span><span class="pelmet-tassel"></span>
      <span class="pelmet-tassel"></span><span class="pelmet-tassel"></span>
      <span class="pelmet-tassel"></span><span class="pelmet-tassel"></span>
      <span class="pelmet-tassel"></span><span class="pelmet-tassel"></span>
      <span class="pelmet-tassel"></span><span class="pelmet-tassel"></span>
    </div>
  </div>

  <!-- Left curtain panel -->
  <div id="reveal-curtain-left" class="curtain-panel">
    <div class="curtain-inner-folds">
      <div class="c-fold"></div><div class="c-fold"></div>
      <div class="c-fold"></div><div class="c-fold"></div>
      <div class="c-fold"></div><div class="c-fold"></div>
    </div>
    <div class="curtain-sheen"></div>
    <div class="curtain-velvet-nap"></div>
  </div>

  <!-- Right curtain panel -->
  <div id="reveal-curtain-right" class="curtain-panel">
    <div class="curtain-inner-folds">
      <div class="c-fold"></div><div class="c-fold"></div>
      <div class="c-fold"></div><div class="c-fold"></div>
      <div class="c-fold"></div><div class="c-fold"></div>
    </div>
    <div class="curtain-sheen curtain-sheen-r"></div>
    <div class="curtain-velvet-nap"></div>
  </div>

  <!-- Gold tie-back: the centre ornament that "holds" curtains -->
  <div class="curtain-tie-centre" id="curtainTie">
    <div class="tie-horizontal">
      <div class="tie-rope-segment"></div>
      <div class="tie-medallion">
        <div class="tie-medallion-ring"></div>
        <span class="tie-medallion-symbol">✦</span>
      </div>
      <div class="tie-rope-segment"></div>
    </div>
    <div class="tie-tassel-group">
      <span class="tie-tassel-thread"></span>
      <span class="tie-tassel-thread"></span>
      <span class="tie-tassel-thread"></span>
      <span class="tie-tassel-thread"></span>
      <span class="tie-tassel-thread"></span>
      <span class="tie-tassel-thread"></span>
      <span class="tie-tassel-thread"></span>
      <span class="tie-tassel-thread"></span>
    </div>
  </div>

  <!-- Centre branding text — visible BEFORE curtain opens -->
  <div id="reveal-text" style="opacity:1">
    <div class="reveal-ornament">✦ &nbsp; ✦ &nbsp; ✦</div>
    <div class="reveal-tagline">AWAKEN THE PRINCESS WITHIN</div>
    <div class="reveal-brand">The Dream Abaya</div>
    <div class="reveal-loading"><div class="reveal-loading-bar"></div></div>
  </div>
</div>
