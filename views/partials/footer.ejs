<style>
.fmodal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,.88);
  z-index: 9990; display: none; align-items: center; justify-content: center;
  padding: 20px; overflow-y: auto;
}
.fmodal-overlay.open { display: flex; }
.fmodal {
  background: #0D1117; border: 1px solid rgba(197,160,89,.25);
  max-width: 620px; width: 100%; max-height: 90vh; overflow-y: auto;
  position: relative; padding: 2.5rem;
  font-family: 'Jost', sans-serif; animation: fmodalIn .3s ease;
}
@keyframes fmodalIn { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:none; } }
.fmodal-close {
  position: absolute; top: 1rem; right: 1rem;
  background: none; border: none; color: rgba(232,229,224,.35);
  font-size: 1.2rem; cursor: pointer; transition: color .2s;
}
.fmodal-close:hover { color: #E8E5E0; }
.fmodal h3 {
  font-family: 'Cormorant Garamond', serif; font-size: 1.6rem;
  font-weight: 300; color: #F0EDE8; margin-bottom: .4rem;
}
.fmodal-ornament { font-size: .65rem; letter-spacing: .4em; color: #C5A059; margin-bottom: 1.4rem; }
.fmodal h4 { font-family: 'Cinzel', serif; font-size: .8rem; letter-spacing: .18em; color: #C5A059; margin: 1.4rem 0 .6rem; }
.fmodal p, .fmodal li { font-size: .85rem; color: rgba(240,237,232,.65); line-height: 1.8; margin-bottom: .5rem; }
.fmodal ul { padding-left: 1.2rem; margin-bottom: 1rem; }
.fmodal li { list-style: none; padding-left: .5rem; }
.fmodal li::before { content: '✦ '; color: rgba(197,160,89,.5); font-size: .6rem; margin-right: 4px; }
.fmodal-divider { height: 1px; background: rgba(197,160,89,.12); margin: 1.2rem 0; }

/* Size guide table */
.size-table { width: 100%; border-collapse: collapse; font-size: .78rem; margin: 1rem 0; }
.size-table th { padding: 8px 12px; font-size: .6rem; letter-spacing: .2em; text-transform: uppercase; color: rgba(232,229,224,.35); border-bottom: 1px solid rgba(197,160,89,.15); text-align: left; }
.size-table td { padding: 9px 12px; border-bottom: 1px solid rgba(255,255,255,.04); color: rgba(240,237,232,.65); }
.size-table tr:hover td { background: rgba(197,160,89,.04); }

/* Contact form */
.fform-field { margin-bottom: 1rem; }
.fform-field label { display: block; font-size: .6rem; letter-spacing: .18em; text-transform: uppercase; color: rgba(232,229,224,.38); margin-bottom: 6px; }
.fform-field input, .fform-field textarea, .fform-field select {
  width: 100%; padding: 10px 14px;
  background: rgba(255,255,255,.04); border: 1px solid rgba(197,160,89,.18);
  color: #F0EDE8; font-size: .84rem; font-family: 'Jost',sans-serif;
  outline: none; transition: border-color .25s;
}
.fform-field input:focus, .fform-field textarea:focus, .fform-field select:focus { border-color: rgba(197,160,89,.5); }
.fform-field textarea { min-height: 110px; resize: vertical; }
.fform-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.fresponse-btns { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 6px; }
.fresponse-btn {
  padding: 7px 16px; border: 1px solid rgba(197,160,89,.25);
  background: transparent; color: rgba(232,229,224,.55);
  font-size: .72rem; letter-spacing: .1em; cursor: pointer; transition: all .2s;
  font-family: 'Jost',sans-serif;
}
.fresponse-btn.selected { border-color: #C5A059; background: rgba(197,160,89,.1); color: #C5A059; }
.fform-success { color: #4CAF50; font-size: .82rem; padding: 12px; background: rgba(76,175,80,.08); border: 1px solid rgba(76,175,80,.2); margin-top: 12px; display: none; }
.fform-error-msg { color: #e74c3c; font-size: .78rem; margin-top: 8px; display: none; }
</style>

<!-- Single modal shell — content swapped by JS -->
<div class="fmodal-overlay" id="footerModal" onclick="if(event.target===this)closeFooterModal()">
  <div class="fmodal">
    <button class="fmodal-close" onclick="closeFooterModal()">✕</button>
    <div id="fmodalContent"></div>
  </div>
</div>

<script>
// ── Footer modal content ──────────────────────────────────────────
const FMODAL_CONTENT = {

  contact: `
