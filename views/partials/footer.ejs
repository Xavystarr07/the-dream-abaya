      We'd love to hear from you. Fill in your enquiry below and we'll get back to you through your preferred channel.
    </p>
    <form id="contactForm" onsubmit="submitContact(event)">
      <input type="hidden" name="access_key" value="e5002887-4b70-43fd-8cf7-fdece5d577f1"/>
      <input type="hidden" name="subject"    value="New Enquiry — The Dream Abaya"/>
      <input type="hidden" name="from_name"  value="The Dream Abaya Website"/>
      <input type="hidden" id="cf-preferred-contact" name="Preferred Contact Method" value=""/>
      <div class="fform-row">
        <div class="fform-field">
          <label>Full Name</label>
          <input type="text" name="name" id="cf-name" placeholder="Your full name" required/>
        </div>
        <div class="fform-field">
          <label>Email Address</label>
          <input type="email" name="email" id="cf-email" placeholder="your@email.com" required/>
        </div>
      </div>
      <div class="fform-row">
        <div class="fform-field">
          <label>Phone Number</label>
          <input type="tel" name="phone" id="cf-phone" placeholder="082 123 4567"/>
        </div>
        <div class="fform-field">
          <label>Order Number <span style="color:rgba(232,229,224,.25)">(if applicable)</span></label>
          <input type="text" name="order_number" placeholder="TDA-XXXXX"/>
        </div>
      </div>
      <div class="fform-field">
        <label>Your Enquiry</label>
        <textarea name="message" placeholder="Tell us how we can help you…" required></textarea>
      </div>
      <div class="fform-field">
        <label>Preferred Response Method</label>
        <div class="fresponse-btns">
          <button type="button" class="fresponse-btn" onclick="selectResponseMethod(this,'Email')">📧 Email</button>
          <button type="button" class="fresponse-btn" onclick="selectResponseMethod(this,'Phone Call')">📞 Phone</button>
          <button type="button" class="fresponse-btn" onclick="selectResponseMethod(this,'WhatsApp')">💬 WhatsApp</button>
        </div>
      </div>
      <div style="margin-top:1.2rem">
        <button type="submit" class="btn-royal" style="width:100%">✦ Send Enquiry</button>
      </div>
      <div class="fform-success" id="cf-success">✓ Your enquiry has been sent. We'll be in touch shortly!</div>
      <div class="fform-error-msg" id="cf-error">Something went wrong. Please try again.</div>
