  shipping: `
    <h3>Shipping Information</h3>
    <div class="fmodal-ornament">✦ &nbsp; ✦ &nbsp; ✦</div>

    <h4>Delivery Across South Africa</h4>
    <p>The Dream Abaya delivers to all major cities and towns across South Africa through our trusted courier partners. All orders are carefully packaged in our signature gift boxes to ensure your garment arrives in perfect condition.</p>

    <div class="fmodal-divider"></div>

    <h4>Delivery Timeframes</h4>
    <ul>
      <li><strong style="color:#F0EDE8">Johannesburg & Pretoria</strong> — 2–3 business days</li>
      <li><strong style="color:#F0EDE8">Cape Town & Durban</strong> — 3–5 business days</li>
      <li><strong style="color:#F0EDE8">Port Elizabeth, Bloemfontein & East London</strong> — 4–6 business days</li>
      <li><strong style="color:#F0EDE8">Rural & Remote Areas</strong> — 5–8 business days</li>
      <li><strong style="color:#F0EDE8">Custom / Made-to-Order Pieces</strong> — 10–14 business days before dispatch</li>
    </ul>

    <div class="fmodal-divider"></div>

    <h4>Shipping Rates</h4>
    <ul>
      <li><strong style="color:#F0EDE8">Standard Delivery</strong> — R95 flat rate nationwide</li>
      <li><strong style="color:#F0EDE8">Express Delivery</strong> — R175 (Gauteng, Western Cape & KZN only)</li>
      <li><strong style="color:#C5A059">FREE Standard Delivery</strong> on all orders over R1,500</li>
    </ul>

    <div class="fmodal-divider"></div>

    <h4>Order Tracking</h4>
    <p>Once your order is dispatched you will receive a confirmation email with your courier tracking number. You can also track your order at any time via <a href="/track" style="color:#C5A059">Track My Order</a> on our website.</p>

    <h4>Important Notes</h4>
    <ul>
      <li>Orders placed before 12:00 PM are processed the same business day</li>
      <li>Delivery times exclude weekends and public holidays</li>
      <li>A signature may be required upon delivery for orders over R2,000</li>
      <li>The Dream Abaya is not liable for delays caused by courier services or force majeure events</li>
    </ul>`,

  returns: `
    <h3>Returns Policy</h3>
    <div class="fmodal-ornament">✦ &nbsp; ✦ &nbsp; ✦</div>

    <p>At The Dream Abaya, every garment is crafted with care and inspected before dispatch. If for any reason you are not completely satisfied, we have made returns as simple as possible.</p>

    <h4>Returns Window</h4>
    <p>You may return most items within <strong style="color:#F0EDE8">14 calendar days</strong> of the delivery date for an exchange or store credit. Refunds to original payment method are processed within <strong style="color:#F0EDE8">7 business days</strong> of us receiving the returned item.</p>

    <div class="fmodal-divider"></div>

    <h4>Eligible for Return</h4>
    <ul>
      <li>Items in their original, unworn condition with all tags attached</li>
      <li>Items in their original packaging</li>
      <li>Items that are faulty, damaged, or incorrectly supplied</li>
    </ul>

    <h4>Not Eligible for Return</h4>
    <ul>
      <li>Custom or made-to-order pieces (unless faulty)</li>
      <li>Perfumes, body mists, and fragrance products (hygiene)</li>
      <li>Items that have been worn, washed, or altered</li>
      <li>Sale items marked as <em>Final Sale</em></li>
      <li>Items without original tags or packaging</li>
    </ul>

    <div class="fmodal-divider"></div>

    <h4>How to Initiate a Return</h4>
    <ul>
      <li>Contact us via the <a href="#" onclick="openFooterModal('contact');return false" style="color:#C5A059">Contact Us</a> form with your order number and reason for return</li>
      <li>We will issue a Return Authorisation Number (RAN) within 24 hours</li>
      <li>Securely package your item and include your RAN inside the parcel</li>
      <li>Drop off at your nearest courier collection point — return shipping is at your cost unless the item is faulty</li>
    </ul>

    <h4>Exchange Policy</h4>
    <p>We are happy to exchange items for a different size or colour, subject to availability. Exchanges are processed within 3–5 business days of receiving your returned item.</p>`,

  sizeguide: `
    <h3>Size Guide</h3>
    <div class="fmodal-ornament">✦ &nbsp; ✦ &nbsp; ✦</div>
    <p>Our abayas and modest pieces are designed with a <strong style="color:#F0EDE8">relaxed, modest fit</strong>. We recommend sizing up if you prefer extra comfort or a more dramatic drape.</p>

    <h4>Abaya & Modest Wear — Women's Sizing</h4>
    <table class="size-table">
      <thead><tr><th>Size</th><th>Bust (cm)</th><th>Waist (cm)</th><th>Hips (cm)</th><th>Length (cm)</th><th>UK Size</th></tr></thead>
      <tbody>
        <tr><td>XS</td><td>80–84</td><td>62–66</td><td>86–90</td><td>135–138</td><td>6–8</td></tr>
        <tr><td>S</td><td>85–90</td><td>67–72</td><td>91–96</td><td>138–140</td><td>10–12</td></tr>
        <tr><td>M</td><td>91–96</td><td>73–78</td><td>97–102</td><td>140–142</td><td>12–14</td></tr>
        <tr><td>L</td><td>97–104</td><td>79–86</td><td>103–110</td><td>142–145</td><td>14–16</td></tr>
        <tr><td>XL</td><td>105–112</td><td>87–94</td><td>111–118</td><td>145–148</td><td>18–20</td></tr>
        <tr><td>XXL</td><td>113–120</td><td>95–102</td><td>119–126</td><td>148–150</td><td>22–24</td></tr>
        <tr><td>Custom</td><td colspan="5" style="color:#C5A059">Contact us for bespoke measurements</td></tr>
      </tbody>
    </table>

    <div class="fmodal-divider"></div>

    <h4>Hijabs</h4>
    <table class="size-table">
      <thead><tr><th>Size Label</th><th>Dimensions</th><th>Best For</th></tr></thead>
      <tbody>
        <tr><td>Standard</td><td>170 × 70 cm</td><td>Everyday wear, easy drape styles</td></tr>
        <tr><td>Standard (180×75cm)</td><td>180 × 75 cm</td><td>Fuller coverage, layered looks</td></tr>
        <tr><td>Large (200×75cm)</td><td>200 × 75 cm</td><td>Turban styles, maximum coverage</td></tr>
        <tr><td>One Size</td><td>Stretch fabric</td><td>Instant hijabs, sports hijabs</td></tr>
      </tbody>
    </table>

    <div class="fmodal-divider"></div>

    <h4>How to Measure</h4>
    <ul>
      <li><strong style="color:#F0EDE8">Bust</strong> — Measure around the fullest part of your chest, keeping the tape parallel to the floor</li>
      <li><strong style="color:#F0EDE8">Waist</strong> — Measure around the narrowest part of your natural waist</li>
      <li><strong style="color:#F0EDE8">Hips</strong> — Measure around the fullest part of your hips, approximately 20 cm below your waist</li>
      <li><strong style="color:#F0EDE8">Length</strong> — Measured from the back of the neck to the floor — standard abaya length is ankle-grazing</li>
    </ul>

    <p style="margin-top:1rem">Need help finding your perfect size? <a href="#" onclick="openFooterModal('contact');return false" style="color:#C5A059">Contact our style team</a> for personalised advice.</p>`
};

function openFooterModal(type) {
  const content = FMODAL_CONTENT[type];
  if (!content) return;
  document.getElementById('fmodalContent').innerHTML = content;
  document.getElementById('footerModal').classList.add('open');
  document.body.style.overflow = 'hidden';

  // Autofill contact form if user is logged in
  if (type === 'contact') {
    const userName  = '<%= locals.user ? locals.user.name  : "" %>';
    const userEmail = '<%= locals.user ? locals.user.email : "" %>';
    const userPhone = '<%= locals.user ? (locals.user.phone||"") : "" %>';
    if (userName)  { const el = document.getElementById('cf-name');  if(el) el.value = userName; }
    if (userEmail) { const el = document.getElementById('cf-email'); if(el) el.value = userEmail; }
    if (userPhone) { const el = document.getElementById('cf-phone'); if(el) el.value = userPhone; }
  }
}

function closeFooterModal() {
  document.getElementById('footerModal').classList.remove('open');
  document.body.style.overflow = '';
}

function selectResponseMethod(btn, method) {
  document.querySelectorAll('.fresponse-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  const el = document.getElementById('cf-preferred-contact');
  if (el) el.value = method;
}

async function submitContact(e) {
  e.preventDefault();
  const form    = document.getElementById('contactForm');
  const success = document.getElementById('cf-success');
  const errorEl = document.getElementById('cf-error');
  const btn     = form.querySelector('button[type=submit]');

  btn.disabled = true;
  btn.textContent = 'Sending…';
  success.style.display = 'none';
  errorEl.style.display = 'none';

  try {
    const res  = await fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(Object.fromEntries(new FormData(form)))
    });
    const data = await res.json();
    if (data.success) {
      success.style.display = 'block';
      form.reset();
    } else {
      errorEl.textContent = data.message || 'Submission failed. Please try again.';
      errorEl.style.display = 'block';
    }
  } catch(err) {
    errorEl.textContent = 'Network error. Please check your connection and try again.';
    errorEl.style.display = 'block';
  } finally {
    btn.disabled = false;
    btn.textContent = '✦ Send Enquiry';
  }
}

// Close on Escape key
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeFooterModal(); });
</script>
