<!DOCTYPE html>
<html lang="en" data-theme="<%= theme %>">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Cinzel:wght@400;500&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/tokens.css"/>
  <link rel="stylesheet" href="/css/nav.css"/>
  <link rel="stylesheet" href="/css/logo.css"/>
  <link rel="stylesheet" href="/css/footer.css"/>
  <link rel="stylesheet" href="/css/products.css"/>
  <link rel="stylesheet" href="/css/utilities.css"/>
  <link rel="stylesheet" href="/css/wishlist.css"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.4/gsap.min.js"></script>
</head>
<body>
  <%- include('js-core') %>
  <%- include('css-base') %>
  <%- include('nav') %>

  <% if (products && products.length > 0) { %>

    <header class="vault-header wishlist-header-royal">
      <canvas class="wishlist-header-canvas" id="wishlistCanvas"></canvas>

      <div class="vault-header-inner">
        <p class="wishlist-header-greeting">
          <%= user ? user.name.split(' ')[0] + "'s" : "Your" %> Collection
        </p>

        <h1 class="vault-title wishlist-shimmer-title">My Wishlist</h1>

        <p class="wishlist-header-tagline">
          <%= products.length %> saved piece<%= products.length !== 1 ? 's' : '' %> · curated with love
        </p>

        <div class="cart-header-divider">
          <div class="cart-header-line"></div>
          <span class="cart-header-ornament">✦ ✦ ✦</span>
          <div class="cart-header-line"></div>
        </div>
      </div>
    </header>

    <main class="vault-main wishlist-main">

      <div class="wishlist-toolbar">
        <span class="wishlist-toolbar-count">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="#e85d75" stroke="#e85d75" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
          <%= products.length %> piece<%= products.length !== 1 ? 's' : '' %> saved
        </span>
        <a href="/vault" class="wishlist-toolbar-browse">Continue browsing →</a>
      </div>

      <div class="products-grid wishlist-grid">
        <% products.forEach(function(p) { %>
          <%- include('product-card', { p }) %>
        <% }); %>
      </div>

    </main>

  <% } else { %>
    <div class="wl-empty-royal">

      <canvas class="wl-empty-canvas" id="wlEmptyCanvas"></canvas>

      <div class="wl-empty-ornament-top">
        <div class="wl-orn-line"></div>
        <span class="wl-orn-diamond"></span>
        <div class="wl-orn-line"></div>
      </div>

      <div class="wl-empty-inner">

        <div class="wl-empty-logo">
          <%- include('logo-svg') %>
        </div>

        <% /* REMOVED: Heart cluster block to create vertical space */ %>

        <h1 class="wl-empty-title">Every Wish Deserves<br>To Come True</h1>
        <p class="wl-empty-sub">One breathtaking piece at a time.</p>

        <div class="wl-empty-divider">
          <div class="wl-orn-line"></div>
          <span class="wl-orn-diamond"></span>
          <div class="wl-orn-line"></div>
        </div>

        <a href="/vault" class="wl-empty-btn">Explore The Vault →</a>

      </div>

      <div class="wl-empty-ornament-bottom">
        <div class="wl-orn-line wl-orn-line--wide"></div>
      </div>

    </div>

    <% if (typeof suggested !== 'undefined' && suggested && suggested.length > 0) { %>
    <section class="wl-suggested">
      <div class="wl-suggested-inner">

        <div class="wl-suggested-header">
          <div class="wl-orn-line"></div>
          <span class="wl-suggested-label">Pieces You May Love</span>
          <div class="wl-orn-line"></div>
        </div>

        <div class="products-grid wl-suggested-grid">
          <% suggested.forEach(function(p) { %>
            <%- include('product-card', { p }) %>
          <% }); %>
        </div>

        <div class="wl-suggested-footer">
          <a href="/vault" class="wl-browse-all">View All Collections →</a>
        </div>

      </div>
    </section>
    <% } %>

  <% } %>

  <script>
    // ── Particle canvas logic (Now focused on dust for elegance) ────────────────────────────
    (function() {
      const canvas = document.getElementById('wlEmptyCanvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      let W, H;
      const particles = [];

      function resize() {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
      }

      function rand(min, max) { return Math.random() * (max - min) + min; }

      function spawnParticle() {
        return {
          x: rand(0, W),
          y: rand(H * 0.1, H),
          size: rand(1, 2.5),
          alpha: rand(0.1, 0.4),
          vx: rand(-0.2, 0.2),
          vy: -rand(0.2, 0.5),
          color: `rgba(197,${Math.floor(rand(130,165))},${Math.floor(rand(50,89))},`
        };
      }

      for (let i = 0; i < 100; i++) particles.push(spawnParticle());

      function draw() {
        ctx.clearRect(0, 0, W, H);
        particles.forEach(p => {
          ctx.save();
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fillStyle = p.color + p.alpha + ')';
          ctx.fill();
          ctx.restore();
          
          p.x += p.vx;
          p.y += p.vy;
          p.alpha -= 0.0005;

          if (p.y < -10 || p.alpha <= 0) {
            Object.assign(p, spawnParticle());
          }
        });
        requestAnimationFrame(draw);
      }

      window.addEventListener('resize', resize);
      resize();
      draw();
    })();

    // ── GSAP animations ─────────────────────────────────────────
    if (typeof gsap !== 'undefined') {
      gsap.from('.wishlist-grid .product-card', {
        opacity: 0, y: 32, duration: 0.6,
        stagger: 0.07, ease: 'power3.out', delay: 0.3
      });
      
      gsap.from('.wishlist-toolbar', {
        opacity: 0, y: -12, duration: 0.5, ease: 'power2.out', delay: 0.2
      });

      const tl = gsap.timeline({ delay: 0.1 });
      tl.from('.wl-empty-ornament-top', { opacity: 0, duration: 0.7 })
        .from('.wl-empty-logo',         { opacity: 0, scale: 0.75, duration: 0.8, ease: 'back.out(1.6)' }, '-=0.3')
        /* REMOVED: Heart cluster GSAP animations */
        .from('.wl-empty-title',        { opacity: 0, y: 28, duration: 0.7, ease: 'power3.out' }, '-=0.2')
        .from('.wl-empty-sub',          { opacity: 0, y: 16, duration: 0.6, ease: 'power2.out' }, '-=0.45')
        .from('.wl-empty-btn',          { opacity: 0, y: 10, duration: 0.5, ease: 'power2.out' }, '-=0.35');

      gsap.from('.wl-suggested-grid .product-card', {
        opacity: 0, y: 28, duration: 0.55,
        stagger: 0.08, ease: 'power3.out', delay: 0.6
      });
    }

    // ── Navbar Scroll Observer ──────────────────────────────────
(function() {
  const nav = document.querySelector('.main-nav');
  if (!nav) return;

  const handleScroll = () => {
    // Threshold of 50px before the background solidifies
    if (window.scrollY > 50) {
      nav.classList.add('nav-scrolled');
    } else {
      nav.classList.remove('nav-scrolled');
    }
  };

  window.addEventListener('scroll', handleScroll);
  // Run once on load in case the user starts halfway down the page
  handleScroll();
})();

// ── Optional: GSAP smoothing for the logo in the nav ────────
if (typeof gsap !== 'undefined') {
  window.addEventListener('scroll', () => {
    const scaleValue = window.scrollY > 50 ? 0.9 : 1;
    gsap.to('.main-nav .brand-logo', {
      scale: scaleValue,
      duration: 0.3,
      ease: 'power1.out'
    });
  });
}
  </script>
</body>
</html>