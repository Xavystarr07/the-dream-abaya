<!DOCTYPE html>
<html lang="en" data-theme="<%= theme %>">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/tokens.css"/>
  <link rel="stylesheet" href="/css/nav.css"/>
  <link rel="stylesheet" href="/css/logo.css"/>
  <link rel="stylesheet" href="/css/footer.css"/>
  <link rel="stylesheet" href="/css/cart.css"/>
  <link rel="stylesheet" href="/css/utilities.css"/>
  <link rel="stylesheet" href="/css/auth.css"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.4/gsap.min.js"></script>
</head>
<body>
  <%- include('css-base') %>
  <%- include('nav') %>

<% if (cart.length > 0) { %>
<header class="vault-header cart-header-royal">
  <canvas id="cartHeaderCanvas" class="cart-header-canvas"></canvas>
  <div class="vault-header-inner">
    <p class="cart-header-greeting">
      <% if (user) { %><%= user.name.split(' ')[0] %>'s Collection<% } else { %>Your Collection<% } %>
    </p>
    <h1 class="vault-title">Shopping Cart</h1>
    <p class="cart-header-tagline"><em>What more shall we add to your world?</em></p>
    <div class="cart-header-divider">
      <span class="cart-header-line"></span>
      <span class="cart-header-ornament">✦</span>
      <span class="cart-header-line"></span>
    </div>
  </div>
</header>
<% } %>

<main class="cart-main<% if (cart.length === 0) { %> cart-main-empty<% } %>">
  <% if (cart.length > 0) { %>
    <div class="cart-layout">
      <div class="cart-left-col">
        <div class="checkout-block" id="checkoutBlock">
          <div class="checkout-block-header">
            <span class="checkout-step-num">1</span>
            <h3>Your Details</h3>
            <p>Fill in your info before placing the order</p>
          </div>
          <div class="checkout-form">
            <div class="checkout-row">
              <div class="checkout-field">
                <label>Full Name *</label>
                <input type="text" id="co_name" class="auth-input" placeholder="Fatima Al-Rashid"
                  value="<%= user ? user.name : '' %>" required maxlength="100"/>
              </div>
              <div class="checkout-field">
                <label>Phone Number *</label>
                <input type="tel" id="co_phone" class="auth-input" placeholder="+27 000 000 0000"
                  value="<%= user && user.phone ? user.phone : '' %>" required inputmode="tel"/>
              </div>
            </div>
            <div class="checkout-field">
              <label>Email Address *</label>
              <input type="email" id="co_email" class="auth-input" placeholder="your@email.com"
                value="<%= user ? user.email : '' %>" required inputmode="email" maxlength="254"/>
            </div>
            <div class="checkout-field">
              <label>Delivery Address *</label>
              <textarea id="co_address" class="auth-input auth-textarea" placeholder="14 Rose Street, Cape Town, 8001&#10;Include suburb &amp; postal code" rows="3" required></textarea>
            </div>
            <div class="checkout-field">
              <label>Special Notes <span style="color:var(--t3)">(optional)</span></label>
              <input type="text" id="co_notes" class="auth-input" placeholder="e.g. gift wrapping, colour preference..."/>
            </div>
          </div>
        </div>

        <div class="checkout-block">
          <div class="checkout-block-header">
            <span class="checkout-step-num">2</span>
            <h3>Your Items</h3>
            <p>Review and adjust quantities</p>
          </div>
          <div class="cart-items">
            <% cart.forEach(function(item) { %>
              <div class="cart-item" data-id="<%= item.id %>" data-size="<%= item.size || '' %>" data-max="<%= item.stock_qty || 99 %>">
                <div class="cart-item-img">
                  <% if (item.image_url) { %>
                    <img src="<%= item.image_url %>" alt="<%= item.name %>" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-flex';"/>
                    <div class="cart-item-placeholder" style="display:none;">✦</div>
                  <% } else { %>
                    <div class="cart-item-placeholder">✦</div>
                  <% } %>
                </div>
                <div class="cart-item-info">
                  <a href="/product/<%= item.id %>" class="cart-item-name"><%= item.name %></a>
                  <% if (item.size) { %><span class="cart-item-size">Size: <%= item.size %></span><% } %>
                  <% if (item.color && item.color !== 'undefined') { %><span class="cart-item-size">Colour: <%= item.color %></span><% } %>
                  <span class="cart-item-price">R<%= Number(item.price).toLocaleString('en-ZA') %> each</span>
                  <% if (item.stock_qty) { %>
                    <span class="stock-indicator <%= item.stock_qty <= 3 ? 'low-stock' : 'in-stock-badge' %>">
                      <%= item.stock_qty <= 3 ? '⚠️ Only ' + item.stock_qty + ' left!' : '✓ ' + item.stock_qty + ' in stock' %>
                    </span>
                  <% } %>
                </div>
                <div class="cart-item-qty">
                  <button onclick="changeQty('<%= item.id %>', '<%= item.size || '' %>', -1)" aria-label="Decrease">−</button>
                  <span class="qty-display"><%= item.qty %></span>
                  <button onclick="changeQty('<%= item.id %>', '<%= item.size || '' %>', 1)" aria-label="Increase">+</button>
                </div>
                <div class="cart-item-subtotal">R<%= Number(item.price * item.qty).toLocaleString('en-ZA') %></div>
                <button class="cart-item-remove" onclick="removeItem('<%= item.id %>', '<%= item.size || '' %>', this)" aria-label="Remove item">✕</button>
              </div>
            <% }); %>
          </div>
        </div>
      </div>

      <div class="cart-summary">
        <h3>Order Summary</h3>
        <div class="cart-summary-lines">
          <% cart.forEach(function(item) { %>
            <div class="cart-summary-line">
              <span><%= item.name %> <small>x<%= item.qty %></small></span>
              <span>R<%= Number(item.price * item.qty).toLocaleString('en-ZA') %></span>
            </div>
          <% }); %>
        </div>
        <div class="cart-summary-divider"></div>
        <div class="cart-summary-line">
          <span>Subtotal</span>
          <span>R<%= Number(total).toLocaleString('en-ZA') %></span>
        </div>
        <div class="cart-summary-line">
          <span>Shipping</span>
          <span class="text-gold">Calculated on order</span>
        </div>
        <div class="cart-summary-total">
          <span>Total</span>
          <span>R<%= Number(total).toLocaleString('en-ZA') %></span>
        </div>

        <button class="" id="cartCheckoutBtn" onclick="openCartPayment()">
          Checkout
          <span class="button__icon-wrapper">
            <svg class="button__icon-svg" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
            <svg class="button__icon-svg button__icon-svg--copy" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </span>
        </button>
        <a href="/vault" class="btn-ghost full-width"><span class="spn2">Continue Shopping</span></a>
        <div class="cart-trust">
          <span>🔒 Secure &amp; Private</span>
          <span>✦ Handcrafted Quality</span>
          <span>📦 5–7 Day Delivery</span>
        </div>
      </div>
    </div>
  <% } %>
</main>
<% if (cart.length === 0) { %>
    <div class="cart-empty-royal">
      <canvas class="cart-empty-canvas" id="cartEmptyCanvas"></canvas>
      <div class="cart-empty-inner">
        <div class="cart-empty-ornament-top">
          <span class="cer-line"></span>
          <span class="cer-diamond"></span>
          <span class="cer-line"></span>
        </div>
        <div class="cart-empty-logo">
          <%- include('logo-svg') %>
        </div>
        <h2 class="cart-empty-heading">Your Cart Awaits</h2>
        <p class="cart-empty-sub">Every royal collection begins with a single choice.</p>
        <div class="cart-empty-ornament-bottom">— ✦ —</div>
        <a href="/vault" class="cart-empty-cta">
          <span class="cta-text">Explore The Vault</span>
          <span class="cta-arrow">→</span>
        </a>
      </div>
    </div>
  <% } %>
</main>

<%- include('js-core') %>
<%- include('footer') %>
<%- include('toast') %>

<script>
  function changeQty(id, size, delta) {
    const item    = document.querySelector('.cart-item[data-id="' + id + '"][data-size="' + size + '"]');
    const display = item.querySelector('.qty-display');
    const max     = parseInt(item.dataset.max) || 99;
    const cur     = parseInt(display.textContent);
    const newQty  = Math.max(1, Math.min(cur + delta, max));

    // Block if already at max
    if (delta > 0 && cur >= max) { showToast('Only ' + max + ' left in stock', 'error'); return; }

    fetch('/cart/update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ product_id: id, size, qty: newQty })
    })
    .then(r => r.json())
    .then(() => {
      // Update qty display in-place
      display.textContent = newQty;

      // Update subtotal for this item
      const priceText = item.querySelector('.cart-item-price')?.textContent || '';
      const unitPrice = parseFloat(priceText.replace(/[^0-9.]/g, '')) || 0;
      const subtotalEl = item.querySelector('.cart-item-subtotal');
      if (subtotalEl) subtotalEl.textContent = 'R' + (unitPrice * newQty).toLocaleString('en-ZA');

      // Recalculate summary totals
      recalcSummary();
    });
  }

  function removeItem(id, size, btn) {
    const item = btn.closest('.cart-item');

    fetch('/cart/remove', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ product_id: id, size })
    })
    .then(r => r.json())
    .then(() => {
      // Animate out then remove from DOM
      if (typeof gsap !== 'undefined') {
        gsap.to(item, {
          opacity: 0, height: 0, marginBottom: 0, paddingTop: 0, paddingBottom: 0,
          duration: 0.35, ease: 'power2.in',
          onComplete: () => { item.remove(); recalcSummary(); }
        });
      } else {
        item.remove();
        recalcSummary();
      }
    });
  }

  function recalcSummary() {
    // Sum all visible cart items
    let total = 0;
    document.querySelectorAll('.cart-item').forEach(item => {
      const priceText = item.querySelector('.cart-item-price')?.textContent || '';
      const qty       = parseInt(item.querySelector('.qty-display')?.textContent) || 0;
      const unitPrice = parseFloat(priceText.replace(/[^0-9.]/g, '')) || 0;
      total += unitPrice * qty;
    });

    const fmt = v => 'R' + v.toLocaleString('en-ZA');

    // Update summary panel
    document.querySelectorAll('.cart-summary-total span:last-child').forEach(el => { el.textContent = fmt(total); });
    document.querySelectorAll('.cart-summary-line').forEach(line => {
      const label = line.querySelector('span:first-child')?.textContent?.toLowerCase() || '';
      if (label === 'subtotal') line.querySelector('span:last-child').textContent = fmt(total);
    });

    // Update checkout button text
    const payBtn = document.getElementById('cartCheckoutBtn');
    if (payBtn) {
      const btnText = payBtn.querySelector('.cta-text') || payBtn.firstChild;
      if (btnText && btnText.nodeType === 3) {
        // text node — update inline
      }
      // Re-set the amountCents global for the payment fetch
      window.__cartTotal = total;
    }

    showToast('Cart updated ✦', 'success');
  }

  function openCartPayment() {
    const name = document.getElementById('co_name')?.value.trim();
    const phone = document.getElementById('co_phone')?.value.trim();
    const email = document.getElementById('co_email')?.value.trim();
    const address = document.getElementById('co_address')?.value.trim();
    const notes = document.getElementById('co_notes')?.value.trim() || '';

    if (!name) { showToast('Please enter your name', 'error'); document.getElementById('co_name').focus(); return; }
    if (!phone) { showToast('Please enter your phone number', 'error'); document.getElementById('co_phone').focus(); return; }
    if (!email) { showToast('Please enter your email', 'error'); document.getElementById('co_email').focus(); return; }
    if (!address) { showToast('Please enter your delivery address', 'error'); document.getElementById('co_address').focus(); return; }

    const amountCents = Math.round((window.__cartTotal || <%= Math.round(total * 100) %> / 100) * 100);
    
    <% 
      const cleanCart = cart.map(function(i) { 
        return { id: i.id, name: i.name, qty: i.qty, size: i.size || '', color: i.color || '', price: i.price }; 
      }); 
    %>
    const items = <%- JSON.stringify(cleanCart) %>; 
    
    const btn = document.getElementById('cartCheckoutBtn');
    btn.innerHTML = 'Redirecting… <span class="button__icon-wrapper"><svg class="button__icon-svg" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>';
    btn.disabled = true;

    fetch('/payment/cart-checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        amountCents: amountCents,
        items: items,
        customer_name: name,
        customer_email: email,
        customer_phone: phone,
        delivery_address: address,
        notes: notes
      })
    })
    .then(r => r.json())
    .then(data => {
      if (data.success && data.redirectUrl) {
        window.location.href = data.redirectUrl;
      } else {
        showToast(data.message || 'Something went wrong.', 'error');
        btn.disabled = false;
        btn.innerHTML = 'Checkout';
      }
    })
    .catch(() => {
      showToast('Network error.', 'error');
      btn.disabled = false;
    });
  }

  // FIXED: GSAP Target validation to stop console errors
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap !== 'undefined') {
      const items = document.querySelectorAll('.cart-item');
      const blocks = document.querySelectorAll('.checkout-block');
      
      if (items.length > 0) {
        gsap.from(items, { opacity: 0, y: 18, duration: 0.5, stagger: 0.07, ease: 'power3.out', delay: 0.25 });
      }
      if (blocks.length > 0) {
        gsap.from(blocks, { opacity: 0, y: 25, duration: 0.6, stagger: 0.12, ease: 'power3.out', delay: 0.15 });
      }
    }
  });
</script>

<script>
(function(){
  function initParticles(canvasId) {
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let W, H, particles = [];

    function resize() {
      W = canvas.offsetWidth;
      H = canvas.offsetHeight;
      canvas.width = W;
      canvas.height = H;
    }
    resize();
    window.addEventListener('resize', () => { resize(); init(); });

    function Particle() {
      this.x = Math.random() * W;
      this.y = Math.random() * H;
      this.r = Math.random() * 1.4 + 0.4;
      this.vx = (Math.random() - .5) * .18;
      this.vy = -(Math.random() * .25 + .08);
      this.life = Math.random();
      this.spd = Math.random() * .004 + .002;
    }
    Particle.prototype.update = function(){
      this.x += this.vx;
      this.y += this.vy;
      this.life += this.spd;
      if (this.y < -4 || this.life > 1) {
        this.y = H + 4;
        this.x = Math.random() * W;
        this.life = 0;
      }
    };
    Particle.prototype.draw = function(){
      const a = Math.sin(this.life * Math.PI) * 0.55 + 0.05;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(197,160,89,' + a + ')';
      ctx.fill();
    };
    function init() {
      particles = [];
      const count = Math.floor((W * H) / 900);
      for (let i = 0; i < count; i++) particles.push(new Particle());
    }
    init();
    function loop() {
      ctx.clearRect(0, 0, W, H);
      particles.forEach(p => { p.update(); p.draw(); });
      requestAnimationFrame(loop);
    }
    loop();
  }
  initParticles('cartHeaderCanvas');
  initParticles('cartEmptyCanvas');
})();
</script>
</body>
</html>