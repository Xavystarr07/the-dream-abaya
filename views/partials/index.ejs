</section>

<!-- ══════════════════════════════════════════════════════════
     SECTION 8 — SEASONAL  (4 seasons chooser)
     ══════════════════════════════════════════════════════════ -->
<section class="elite-section seasonal-section" id="section-seasonal">
  <canvas class="section-canvas" id="seasonalCanvas"></canvas>
  <div class="section-bg-seasonal"></div>

  <!-- Intro poem text -->
  <div class="seasonal-intro" id="seasonalIntro">
    <div class="section-badge seasonal-badge">Seasonal Collections</div>
    <h2 class="section-heading elite-heading">Dressed for<br/><em>Every Season</em></h2>
    <p class="seasonal-poem">
      As the earth turns and the seasons change,<br/>
      so does the language of modest fashion.<br/>
      <em>Which season speaks to you today?</em>
    </p>
  </div>

  <!-- Immersive season overlay canvas (contained within section) -->
  <canvas id="seasonImmersiveCanvas" class="season-immersive-canvas" style="display:none;position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:5"></canvas>

  <!-- Season chooser -->
  <div class="season-chooser" id="seasonChooser">
    <button class="season-card season-summer" onclick="selectSeason('summer')">
      <canvas class="season-mini-canvas" id="summerCanvas" width="160" height="160"></canvas>
      <!-- Elegant geometric sun — replaces emoji -->
      <div class="season-icon">
        <svg viewBox="0 0 48 48" width="48" height="48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="24" cy="24" r="9" stroke="#C5A059" stroke-width="2" fill="rgba(197,160,89,0.15)"/>
          <line x1="24" y1="4"  x2="24" y2="10" stroke="#C5A059" stroke-width="2" stroke-linecap="round"/>
          <line x1="24" y1="38" x2="24" y2="44" stroke="#C5A059" stroke-width="2" stroke-linecap="round"/>
          <line x1="4"  y1="24" x2="10" y2="24" stroke="#C5A059" stroke-width="2" stroke-linecap="round"/>
          <line x1="38" y1="24" x2="44" y2="24" stroke="#C5A059" stroke-width="2" stroke-linecap="round"/>
          <line x1="9.37"  y1="9.37"  x2="13.6"  y2="13.6"  stroke="#C5A059" stroke-width="2" stroke-linecap="round"/>
          <line x1="34.4"  y1="34.4"  x2="38.63" y2="38.63" stroke="#C5A059" stroke-width="2" stroke-linecap="round"/>
          <line x1="38.63" y1="9.37"  x2="34.4"  y2="13.6"  stroke="#C5A059" stroke-width="2" stroke-linecap="round"/>
          <line x1="13.6"  y1="34.4"  x2="9.37"  y2="38.63" stroke="#C5A059" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="season-name">Summer</div>
      <div class="season-desc">Light linens, soft pastels</div>
    </button>
    <button class="season-card season-autumn" onclick="selectSeason('autumn')">
      <canvas class="season-mini-canvas" id="autumnCanvas" width="160" height="160"></canvas>
      <!-- Elegant leaf — replaces emoji -->
      <div class="season-icon">
        <svg viewBox="0 0 48 48" width="48" height="48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M24 6 C36 6 42 16 38 28 C34 38 22 44 14 38 C6 32 8 18 24 6 Z" stroke="#C5A059" stroke-width="2" fill="rgba(197,160,89,0.12)"/>
          <path d="M24 6 L20 38" stroke="#C5A059" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M20 20 C24 18 30 20 32 24" stroke="#C5A059" stroke-width="1.2" stroke-linecap="round" fill="none"/>
          <path d="M18 28 C22 26 28 27 30 31" stroke="#C5A059" stroke-width="1.2" stroke-linecap="round" fill="none"/>
        </svg>
      </div>
      <div class="season-name">Autumn</div>
      <div class="season-desc">Warm tones, layered richness</div>
    </button>
    <button class="season-card season-winter" onclick="selectSeason('winter')">
      <canvas class="season-mini-canvas" id="winterCanvas" width="160" height="160"></canvas>
      <!-- Elegant snowflake — replaces emoji -->
      <div class="season-icon">
        <svg viewBox="0 0 48 48" width="48" height="48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="24" y1="6"  x2="24" y2="42" stroke="#C5A059" stroke-width="2" stroke-linecap="round"/>
          <line x1="6"  y1="24" x2="42" y2="24" stroke="#C5A059" stroke-width="2" stroke-linecap="round"/>
          <line x1="10.06" y1="10.06" x2="37.94" y2="37.94" stroke="#C5A059" stroke-width="2" stroke-linecap="round"/>
          <line x1="37.94" y1="10.06" x2="10.06" y2="37.94" stroke="#C5A059" stroke-width="2" stroke-linecap="round"/>
          <!-- branch tips -->
          <line x1="24" y1="6"  x2="20" y2="10" stroke="#C5A059" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="24" y1="6"  x2="28" y2="10" stroke="#C5A059" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="24" y1="42" x2="20" y2="38" stroke="#C5A059" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="24" y1="42" x2="28" y2="38" stroke="#C5A059" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="6"  y1="24" x2="10" y2="20" stroke="#C5A059" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="6"  y1="24" x2="10" y2="28" stroke="#C5A059" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="42" y1="24" x2="38" y2="20" stroke="#C5A059" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="42" y1="24" x2="38" y2="28" stroke="#C5A059" stroke-width="1.4" stroke-linecap="round"/>
          <circle cx="24" cy="24" r="3" fill="#C5A059" opacity="0.6"/>
        </svg>
      </div>
      <div class="season-name">Winter</div>
      <div class="season-desc">Velvet depth, royal textures</div>
    </button>
    <button class="season-card season-spring" onclick="selectSeason('spring')">
      <canvas class="season-mini-canvas" id="springCanvas" width="160" height="160"></canvas>
      <!-- Elegant blossom — replaces emoji -->
      <div class="season-icon">
        <svg viewBox="0 0 48 48" width="48" height="48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="24" cy="14" rx="5" ry="8" fill="rgba(197,160,89,0.2)" stroke="#C5A059" stroke-width="1.6" transform="rotate(0 24 24)"/>
          <ellipse cx="24" cy="14" rx="5" ry="8" fill="rgba(197,160,89,0.2)" stroke="#C5A059" stroke-width="1.6" transform="rotate(72 24 24)"/>
          <ellipse cx="24" cy="14" rx="5" ry="8" fill="rgba(197,160,89,0.2)" stroke="#C5A059" stroke-width="1.6" transform="rotate(144 24 24)"/>
          <ellipse cx="24" cy="14" rx="5" ry="8" fill="rgba(197,160,89,0.2)" stroke="#C5A059" stroke-width="1.6" transform="rotate(216 24 24)"/>
          <ellipse cx="24" cy="14" rx="5" ry="8" fill="rgba(197,160,89,0.2)" stroke="#C5A059" stroke-width="1.6" transform="rotate(288 24 24)"/>
          <circle cx="24" cy="24" r="5" fill="#C5A059" opacity="0.7"/>
        </svg>
      </div>
      <div class="season-name">Spring</div>
      <div class="season-desc">Florals, soft blossoms</div>
    </button>
  </div>

  <!-- Season display panel (shown after selection) -->
  <div class="season-display" id="seasonDisplay" style="display:none">
    <div class="season-display-inner">
      <button class="season-back-btn" onclick="closeSeason()">← Back to Seasons</button>
      <div class="season-display-header">
        <span class="season-display-icon" id="sdIcon"></span>
        <h2 class="season-display-title" id="sdTitle"></h2>
        <p class="season-display-poem" id="sdPoem"></p>
      </div>
      <!-- Products from relevant categories for each season -->
      <div class="products-row elite-products-row" id="seasonProducts"></div>
      <div style="text-align:center;margin-top:2rem">
        <a id="seasonViewAll" href="/vault" class="btn-royal-elite">View Full Collection →</a>
      </div>
    </div>
  </div>
</section>

