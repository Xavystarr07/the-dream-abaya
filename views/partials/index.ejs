    <canvas id="handbagsCanvas" class="handbags-canvas"></canvas>
  </div>

  <div class="section-content-panel" id="hijabsContent">
    <div class="section-header-block">
      <div class="section-badge hijab-badge-elite">Hijabs & Niqabs</div>
      <h2 class="section-heading elite-heading">Crown Your<br/><em>Modesty</em></h2>
      <p class="section-subheading">From everyday jerseys to embroidered occasion pieces. Your hijab, your crown.</p>
    </div>
    <div class="products-row elite-products-row">
      <% sections.hijabs.slice(0,4).forEach(function(p){ %>
        <%- include('product-card', { p }) %>
