  <canvas class="section-canvas" id="perfumeCanvas"></canvas>
  <div class="section-bg-perfumes"></div>

  <!-- Perfume stage removed — floating bottles cleaned up -->

  <div class="section-content-panel" id="perfumesContent">
    <div class="section-header-block">
      <div class="section-badge perfume-badge-elite">Perfumes</div>
      <h2 class="section-heading elite-heading">Scent of<br/><em>Jannah</em></h2>
