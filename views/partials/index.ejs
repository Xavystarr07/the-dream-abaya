          <div class="story-divider">— ✦ —</div>
          <div class="story-stat"><span class="stat-num">100%</span><span class="stat-label">Halal & Modest</span></div>
          <div class="story-divider">— ✦ —</div>
          <div class="story-stat"><span class="stat-num">Est.</span><span class="stat-label">2024 · South Africa</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

