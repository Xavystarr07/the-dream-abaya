<!-- ══════════════════════════════════════════════════════════
     SECTION 6 — ACCESSORIES  (purple→blue, handbag lady walks)
     ══════════════════════════════════════════════════════════ -->
<section class="elite-section accessories-section-elite" id="section-accessories">
  <div class="section-bg-accessories"></div>
  <canvas class="section-canvas" id="accessoriesCanvas"></canvas>

  <!-- Floating perfume bottles canvas animation -->
  <div class="perfumes-float-stage" id="perfumesFloatStage">
    <canvas id="perfumesFloatCanvas" class="perfumes-float-canvas"></canvas>
  </div>

  <div class="section-content-panel" id="accessoriesContent">
    <div class="section-header-block">
      <div class="section-badge accessories-badge-elite">Accessories</div>
      <h2 class="section-heading elite-heading">The Finishing<br/><em>Touch</em></h2>
      <p class="section-subheading">Pins, belts, bags, and prayer beads. Details that define who you are.</p>
    </div>
    <div class="products-row elite-products-row">
      <% sections.accessories.slice(0,4).forEach(function(p){ %>
        <%- include('product-card', { p }) %>
      <% }) %>
    </div>
    <div style="text-align:center;margin-top:2rem">
      <a href="/vault?category=accessories" class="btn-royal-elite">View All Accessories <span>→</span></a>
    </div>
  </div>
</section>

