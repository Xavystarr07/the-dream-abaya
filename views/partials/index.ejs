<!-- ══════════════════════════════════════════════════════════
     SECTION 8 — SEASONAL  (4 seasons chooser)
     ══════════════════════════════════════════════════════════ -->
<section class="elite-section seasonal-section" id="section-seasonal">
  <canvas class="section-canvas" id="seasonalCanvas"></canvas>
  <div class="section-bg-seasonal"></div>

  <!-- Intro poem text -->
  <div class="seasonal-intro" id="seasonalIntro">
    <div class="section-badge seasonal-badge">Seasonal Collections</div>
    <h2 class="section-heading elite-heading">Dressed for<br/><em>Every Season</em></h2>
    <p class="seasonal-poem">
      As the earth turns and the seasons change,<br/>
      so does the language of modest fashion.<br/>
      <em>Which season speaks to you today?</em>
    </p>
  </div>

  <!-- Immersive season overlay canvas (contained within section) -->
  <canvas id="seasonImmersiveCanvas" class="season-immersive-canvas" style="display:none;position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:5"></canvas>

  <!-- Season chooser -->
  <div class="season-chooser" id="seasonChooser">
    <button class="season-card season-summer" onclick="selectSeason('summer')">
      <canvas class="season-mini-canvas" id="summerCanvas" width="160" height="160"></canvas>
      <!-- Elegant geometric sun — replaces emoji -->
      <div class="season-icon">☀️</div>
      <div class="season-name">Summer</div>
      <div class="season-desc">Light linens, soft pastels</div>
    </button>
    <button class="season-card season-autumn" onclick="selectSeason('autumn')">
      <canvas class="season-mini-canvas" id="autumnCanvas" width="160" height="160"></canvas>
      <!-- Elegant leaf — replaces emoji -->
      <div class="season-icon">🍂</div>
      <div class="season-name">Autumn</div>
      <div class="season-desc">Warm tones, layered richness</div>
    </button>
    <button class="season-card season-winter" onclick="selectSeason('winter')">
      <canvas class="season-mini-canvas" id="winterCanvas" width="160" height="160"></canvas>
      <!-- Elegant snowflake — replaces emoji -->
      <div class="season-icon">❄️</div>
      <div class="season-name">Winter</div>
      <div class="season-desc">Velvet depth, royal textures</div>
    </button>
    <button class="season-card season-spring" onclick="selectSeason('spring')">
      <canvas class="season-mini-canvas" id="springCanvas" width="160" height="160"></canvas>
      <!-- Elegant blossom — replaces emoji -->
      <div class="season-icon">
        <div class="season-icon">🌸</div>
      <div class="season-name">Spring</div>
      <div class="season-desc">Florals, soft blossoms</div>
    </button>
  </div>

  <!-- Season display panel (shown after selection) -->
  <div class="season-display" id="seasonDisplay" style="display:none">
    <div class="season-display-inner">
      <button class="season-back-btn" onclick="closeSeason()">← Back to Seasons</button>
      <div class="season-display-header">
        <span class="season-display-icon" id="sdIcon"></span>
        <h2 class="season-display-title" id="sdTitle"></h2>
        <p class="season-display-poem" id="sdPoem"></p>
      </div>
      <!-- Products from relevant categories for each season -->
      <div class="products-row elite-products-row" id="seasonProducts"></div>
      <div style="text-align:center;margin-top:2rem">
        <a id="seasonViewAll" href="/vault" class="btn-royal-elite">View Full Collection →</a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════
     BRAND STORY
     ══════════════════════════════════════════════════════════ -->
<section class="elite-story" id="story-section">
  <div class="story-inner">

    <div class="story-text reveal-block">
      <div class="story-ornament">
        <span class="story-orn-line"></span>
        <span class="story-orn-diamond">✦</span>
        <span class="story-orn-line"></span>
      </div>
      <div class="section-badge" style="margin-bottom:1rem">Our Story</div>
      <h2 class="section-heading elite-heading" style="margin-bottom:1.5rem">Born From<br/><em>A Vision</em></h2>
      <blockquote class="story-quote">
        "Modesty is not a limitation — it is a canvas."
      </blockquote>
      <p>The Dream Abaya was born from a conviction: that the woman who covers deserves couture, not compromise. Every piece is cut from premium fabric, finished by hand, and held to the standard of a R20,000 gown.</p>
      <p>We believe covering is an act of power. Every stitch, every silhouette, every detail we craft is a quiet declaration — <em>I choose this. And I choose to be extraordinary in it.</em></p>
      <div class="story-divider-gold"></div>
      <p class="story-mission">South African. Proudly modest. Uncompromisingly beautiful.</p>
    </div>

    <div class="story-visual reveal-block">
      <div class="story-frame">
        <div class="story-frame-inner">
          <div class="story-stat">
            <span class="stat-num">24+</span>
            <span class="stat-label">Unique Pieces</span>
          </div>
          <div class="story-divider">— ✦ —</div>
          <div class="story-stat">
            <span class="stat-num">100%</span>
            <span class="stat-label">Halal &amp; Modest</span>
          </div>
          <div class="story-divider">— ✦ —</div>
          <div class="story-stat">
            <span class="stat-num">Est.</span>
            <span class="stat-label">2024 · South Africa</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

