<!-- ══════════════════════════════════════════════════════════
     SECTION 1 — HERO SLIDER  (fireworks slide 1 + image slides)
     ══════════════════════════════════════════════════════════ -->
<section class="hero-slider-section" id="hero">

  <!-- Arrow navigation -->
  <div class="hero-slider-prev">
    <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
  </div>
  <div class="hero-slider-next">
    <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
  </div>

  <div class="hero-swiper swiper">
    <div class="swiper-wrapper">

      <!-- ── SLIDE 1: FIREWORKS CANVAS ── -->
      <div class="swiper-slide">
        <!-- Stars + fireworks canvases live here -->
        <canvas id="fireworksCanvas" class="hero-canvas-layer" style="position:absolute;inset:0;width:100%;height:100%;z-index:2;pointer-events:none;"></canvas>
        <!-- Cloud layer -->
        <div class="hero-clouds" id="heroClouds">
          <div class="cloud cloud-1"></div>
          <div class="cloud cloud-2"></div>
          <div class="cloud cloud-3"></div>
          <div class="cloud cloud-4"></div>
          <div class="cloud cloud-5"></div>
          <div class="cloud cloud-6"></div>
        </div>
        
        <div class="slide-content slide-fireworks-content">
          <span class="slide-eyebrow">Est 2026</span>
          <h1 class="slide-title-main">Where dreams come true </h1>
          <p class="slide-sub">Luxury modest fashion, crafted for the woman who leads with grace.</p>
          <a href="/vault" class="slide-cta">Explore Our Collection →</a>
        </div>
      </div>

      <!-- ── SLIDE 2: DREAM ABAYAS ── -->
      <div class="swiper-slide">
        <div class="slide-bg" style="background-image: url('images/main page/couture.jpeg');"></div>
        
        <div class="slide-content">
          <span class="slide-eyebrow">Absolute Princess</span>
          <h1 class="slide-title">Couture<br/><em>Abayas</em></h1>
          <p class="slide-sub">For women who refuse to be ordinary. Each piece is a statement of power and grace.</p>
          <a href="/vault?category=dream" class="slide-cta">View All Dream Abayas →</a>
        </div>
      </div>

      <!-- ── SLIDE 3: MODEST ── -->
      <div class="swiper-slide">
        <div class="slide-bg" style="background-image: url('images/main page/m&b.jpeg');"></div>
        
        <div class="slide-content">
          <span class="slide-eyebrow">Stylish & Budget-Friendly</span>
          <h1 class="slide-title">Modest &<br/><em>Beautiful</em></h1>
          <p class="slide-sub">Elegance shouldn't cost a fortune. Modesty for every day, every occasion.</p>
          <a href="/vault?category=modest" class="slide-cta">View Modest Pieces →</a>
        </div>
      </div>

      <!-- ── SLIDE 4: AESTHETIC ── -->
      <div class="swiper-slide">
        <div class="slide-bg" style="background-image: url('images/main page/S&A.jpeg');"></div>
        <div class="slide-content">
          <span class="slide-eyebrow">Clean. Calm. Considered.</span>
          <h1 class="slide-title">Simply<br/><em>Aesthetic</em></h1>
          <p class="slide-sub">Minimal silhouettes in earthy, natural tones. Aesthetic without effort.</p>
          <a href="/vault?category=aesthetic" class="slide-cta">View All Aesthetic →</a>
        </div>
      </div>

      <!-- ── SLIDE 5: HIJABS ── -->
      <div class="swiper-slide">
        <div class="slide-bg" style="background-image: url('images/main page/H&N.jpeg');"></div>
        
        <div class="slide-content">
          <span class="slide-eyebrow">Crown Your Modesty</span>
          <h1 class="slide-title">Hijabs &<br/><em>Niqabs</em></h1>
          <p class="slide-sub">From everyday jerseys to embroidered occasion pieces. Your hijab, your crown.</p>
          <a href="/vault?category=hijabs" class="slide-cta">View All Hijabs →</a>
        </div>
      </div>

      <!-- ── SLIDE 6: PERFUMES ── -->
      <div class="swiper-slide">
        <div class="slide-bg" style="background-image: url('images/main page/perfume.jpeg');"></div>
        
        <div class="slide-content">
          <span class="slide-eyebrow">Scent of Jannah</span>
          <h1 class="slide-title">Pure<br/><em>Perfumes</em></h1>
          <p class="slide-sub">Alcohol-free. Halal-certified. Wear the scent of paradise.</p>
          <a href="/vault?category=perfumes" class="slide-cta">View All Perfumes →</a>
        </div>
      </div>

      <!-- ── SLIDE 7: SEASONAL ── -->
      <div class="swiper-slide">
        <div class="slide-bg" style="background-image: url('images/main page/season.jpeg');"></div>
        
        <div class="slide-content">
          <span class="slide-eyebrow">Dressed for Every Season</span>
          <h1 class="slide-title">Seasonal<br/><em>Collections</em></h1>
          <p class="slide-sub">As the earth turns, so does the language of modest fashion.</p>
          <a href="/vault?section=seasonal" class="slide-cta">View Seasonal →</a>
        </div>
      </div>

    </div><!-- /swiper-wrapper -->
