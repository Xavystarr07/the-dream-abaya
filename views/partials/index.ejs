<script>
  // Force canvas dimensions using window size BEFORE init
  // (canvas.offsetWidth = 0 inside Swiper translate)
  function primeCanvases() {
    ['fireworksCanvas'].forEach(id => {
      const c = document.getElementById(id);
      if (c) {
        c.width  = window.innerWidth;
        c.height = window.innerHeight;
        // Also fix CSS so it fills the slide
        c.style.width  = '100%';
        c.style.height = '100%';
        c.style.position = 'absolute';
        c.style.top = '0';
        c.style.left = '0';
      }
    });
  }

  primeCanvases();               // set buffer size immediately
  initStarField();               // now has real dimensions
  initFireworks();               // same

  window.__eliteCanvasReady = true;

  initHeroSlider();
  initScrollSnap();
  initReveal();
  initElitePage();
</script>
