<!DOCTYPE html>
<html lang="en" data-theme="<%= theme %>" id="top">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Cinzel:wght@400;500;600;700&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet"/>
  <!-- ── CORE (load first — variables & reset) ── -->
  <link rel="stylesheet" href="/css/tokens.css"/>
  <link rel="stylesheet" href="/css/animations.css"/>
  <link rel="stylesheet" href="/css/utilities.css"/>
  <!-- ── LAYOUT COMPONENTS ── -->
  <link rel="stylesheet" href="/css/reveal.css"/>
  <link rel="stylesheet" href="/css/nav.css"/>
  <link rel="stylesheet" href="/css/logo.css"/>
  <link rel="stylesheet" href="/css/footer.css"/>
  <!-- ── PAGE SECTIONS ── -->
  <link rel="stylesheet" href="/css/hero.css"/>
  <link rel="stylesheet" href="/css/sections.css"/>
  <link rel="stylesheet" href="/css/seasons.css"/>
  <!-- ── FEATURE PAGES ── -->
  <link rel="stylesheet" href="/css/products.css"/>
  <link rel="stylesheet" href="/css/cart.css"/>
  <link rel="stylesheet" href="/css/auth.css"/>
  <link rel="stylesheet" href="/css/track.css"/>

  <link rel="stylesheet" href="/css/nav-fixes.css"/>
  <link rel="stylesheet" href="/css/hero-fixes.css"/>
  <link rel="stylesheet" href="/css/hero-slider.css"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>

  <link rel="icon" href="data:,">
  
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.4/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.4/ScrollTrigger.min.js"></script>
</head>
<body class="elite-page">

  <%- include('css-base') %>
<%- include('reveal') %>
<%- include('nav') %>

<!-- Motion blur SVG filter (hidden) -->
<svg xmlns="http://www.w3.org/2000/svg" style="display:none">
  <defs>
    <filter id="hero-motion-blur">
      <feGaussianBlur in="SourceGraphic" stdDeviation="0,0"/>
    </filter>
  </defs>
</svg>

<!-- ══════════════════════════════════════════════════════════
     SECTION 1 — HERO SLIDER  (fireworks slide 1 + image slides)
     ══════════════════════════════════════════════════════════ -->
<section class="hero-slider-section" id="hero">

  <!-- Arrow navigation -->
  <div class="hero-slider-prev">
    <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
  </div>
  <div class="hero-slider-next">
    <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
  </div>

  <div class="hero-swiper swiper">
    <div class="swiper-wrapper">

      <!-- ── SLIDE 1: FIREWORKS CANVAS ── -->
      <div class="swiper-slide">
        <!-- Stars + fireworks canvases live here -->
        <canvas id="starsCanvas" class="hero-canvas-layer" style="z-index:1"></canvas>
        <canvas id="fireworksCanvas" class="hero-canvas-layer" style="z-index:2"></canvas>
        <!-- Cloud layer -->
        <div class="hero-clouds" id="heroClouds">
          <div class="cloud cloud-1"></div>
          <div class="cloud cloud-2"></div>
          <div class="cloud cloud-3"></div>
          <div class="cloud cloud-4"></div>
          <div class="cloud cloud-5"></div>
          <div class="cloud cloud-6"></div>
        </div>
        
        <div class="slide-content slide-fireworks-content">
          <span class="slide-eyebrow">New Arrivals 2026</span>
          <h1 class="slide-title">Where Modesty<br/><em>Meets Majesty</em></h1>
          <p class="slide-sub">Luxury modest fashion, crafted for the woman who leads with grace.</p>
          <a href="/vault" class="slide-cta">Explore The Collection →</a>
        </div>
      </div>

      <!-- ── SLIDE 2: DREAM ABAYAS ── -->
      <div class="swiper-slide">
        <div class="slide-bg" style="background-image:url('https://images.unsplash.com/photo-1563170351-be32388e0c89?q=80&w=2000'); filter:url(#hero-motion-blur)"></div>
        
        <div class="slide-content">
          <span class="slide-eyebrow">Absolute Princess</span>
          <h1 class="slide-title">Couture<br/><em>Abayas</em></h1>
          <p class="slide-sub">For women who refuse to be ordinary. Each piece is a statement of power and grace.</p>
          <a href="/vault?category=dream" class="slide-cta">View All Dream Abayas →</a>
        </div>
      </div>

      <!-- ── SLIDE 3: MODEST ── -->
      <div class="swiper-slide">
        <div class="slide-bg" style="background-image:url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?q=80&w=2000'); filter:url(#hero-motion-blur)"></div>
        
        <div class="slide-content">
          <span class="slide-eyebrow">Stylish & Budget-Friendly</span>
          <h1 class="slide-title">Modest &<br/><em>Beautiful</em></h1>
          <p class="slide-sub">Elegance shouldn't cost a fortune. Modesty for every day, every occasion.</p>
          <a href="/vault?category=modest" class="slide-cta">View Modest Pieces →</a>
        </div>
      </div>

      <!-- ── SLIDE 4: AESTHETIC ── -->
      <div class="swiper-slide">
        <div class="slide-bg" style="background-image:url('https://images.unsplash.com/photo-1596541243179-8488e0797371?q=80&w=2000'); filter:url(#hero-motion-blur)"></div>
        
        <div class="slide-content">
          <span class="slide-eyebrow">Clean. Calm. Considered.</span>
          <h1 class="slide-title">Simply<br/><em>Aesthetic</em></h1>
          <p class="slide-sub">Minimal silhouettes in earthy, natural tones. Aesthetic without effort.</p>
          <a href="/vault?category=aesthetic" class="slide-cta">View All Aesthetic →</a>
        </div>
      </div>

      <!-- ── SLIDE 5: HIJABS ── -->
      <div class="swiper-slide">
        <div class="slide-bg" style="background-image:url('https://images.unsplash.com/photo-1601121141461-9d6647bca1ed?q=80&w=2000'); filter:url(#hero-motion-blur)"></div>
        
        <div class="slide-content">
          <span class="slide-eyebrow">Crown Your Modesty</span>
          <h1 class="slide-title">Hijabs &<br/><em>Niqabs</em></h1>
          <p class="slide-sub">From everyday jerseys to embroidered occasion pieces. Your hijab, your crown.</p>
          <a href="/vault?category=hijabs" class="slide-cta">View All Hijabs →</a>
        </div>
      </div>

      <!-- ── SLIDE 6: PERFUMES ── -->
      <div class="swiper-slide">
        <div class="slide-bg" style="background-image:url('https://images.unsplash.com/photo-1594035910387-fea47794261f?q=80&w=2000'); filter:url(#hero-motion-blur)"></div>
        
        <div class="slide-content">
          <span class="slide-eyebrow">Scent of Jannah</span>
          <h1 class="slide-title">Pure<br/><em>Perfumes</em></h1>
          <p class="slide-sub">Alcohol-free. Halal-certified. Wear the scent of paradise.</p>
          <a href="/vault?category=perfumes" class="slide-cta">View All Perfumes →</a>
        </div>
      </div>

      <!-- ── SLIDE 7: SEASONAL ── -->
      <div class="swiper-slide">
        <div class="slide-bg" style="background-image:url('https://images.unsplash.com/photo-1520006403909-838d6b92c22e?q=80&w=2000'); filter:url(#hero-motion-blur)"></div>
        
        <div class="slide-content">
          <span class="slide-eyebrow">Dressed for Every Season</span>
          <h1 class="slide-title">Seasonal<br/><em>Collections</em></h1>
          <p class="slide-sub">As the earth turns, so does the language of modest fashion.</p>
          <a href="/vault?section=seasonal" class="slide-cta">View Seasonal →</a>
        </div>
      </div>

    </div><!-- /swiper-wrapper -->
    <div class="swiper-pagination"></div>
  </div><!-- /hero-swiper -->

</section>

<!-- ══════════════════════════════════════════════════════════
     SECTION 2 — THE DREAM ABAYA  (purple→blue, princess anim)
     ══════════════════════════════════════════════════════════ -->
<section class="elite-section dream-section" id="section-dream">
  <canvas class="section-canvas" id="dreamCanvas"></canvas>
  <div class="section-bg-dream"></div>

  <!-- Floating clouds + petals canvas animation -->
  <div class="dream-floats-stage" id="dreamFloatsStage">
    <canvas id="dreamFloatsCanvas" class="dream-floats-canvas"></canvas>
  </div>

  <div class="section-content-panel" id="dreamContent">
    <div class="section-header-block">
      <div class="section-badge dream-badge-elite">The Dream Abaya</div>
      <h2 class="section-heading elite-heading">Absolute<br/><em>Princess</em></h2>
      <p class="section-subheading">Couture abayas for women who refuse to be ordinary. Each piece is a statement of power and grace.</p>
    </div>
    <div class="products-row elite-products-row">
      <% sections.dream.slice(0,4).forEach(function(p){ %>
        <%- include('product-card', { p }) %>
      <% }) %>
    </div>
    <div style="text-align:center;margin-top:2rem">
      <a href="/vault?category=dream" class="btn-royal-elite">View All Dream Abayas <span>→</span></a>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════
     SECTION 3 — MODEST & BEAUTIFUL  (blue, floating feather + flower)
     ══════════════════════════════════════════════════════════ -->
