     SECTION 4 — SIMPLY AESTHETIC  (blue, floating hearts)
     ══════════════════════════════════════════════════════════ -->
<section class="elite-section aesthetic-section-elite" id="section-aesthetic">
  <canvas class="section-canvas" id="crownsCanvas"></canvas>
  <div class="section-bg-aesthetic"></div>

  <div class="section-content-panel" id="aestheticContent">
    <div class="section-header-block">
      <div class="section-badge aesthetic-badge-elite">Simply Aesthetic</div>
      <h2 class="section-heading elite-heading">Clean.<br/><em>Calm. Considered.</em></h2>
      <p class="section-subheading">Minimal silhouettes in earthy, natural tones. Aesthetic without effort.</p>
