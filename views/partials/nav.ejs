<!-- ══ NAVIGATION ════════════════════════════════════════════ -->
<nav class="royal-nav" id="royalNav">
  <div class="nav-inner">
    <!-- Logo: scroll to top, not reload -->
    <!-- Logo: uses inline SVG partial for crisp rendering at all sizes -->
    <a href="#top" class="nav-logo nav-logo-img" onclick="event.preventDefault(); window.scrollTo({top:0,behavior:'smooth'})" aria-label="The Dream Abaya">
      <%- include('./logo-svg') %>
    </a>

    <ul class="nav-links">
      <li><a href="/" class="nav-link <%= page==='home'?'active':'' %>" id="homeNavLink"
  onclick="if(window.location.pathname==='/'){event.preventDefault();window.scrollTo({top:0,behavior:'smooth'})}">Home</a></li>

      <!-- Collections: click-based, not hover-lost -->
      <li class="nav-dropdown" id="collectionsDropdown">
        <button class="nav-link nav-link-drop" onclick="toggleDropdown('collectionsDropdown')" aria-expanded="false" aria-haspopup="true">
          Collections
          <svg class="dropdown-arrow" width="10" height="6" viewBox="0 0 10 6"><path d="M0 0l5 6 5-6z" fill="currentColor"/></svg>
        </button>
        <div class="nav-dropdown-menu" id="collectionsMenu">
          <a href="/vault?category=dream">👑 The Dream Abaya</a>
          <a href="/vault?category=modest">🌸 Modest & Beautiful</a>
          <a href="/vault?category=aesthetic">🤍 Simply Aesthetic</a>
          <a href="/vault?category=hijabs">🕌 Hijabs & Niqabs</a>
          <a href="/vault?category=accessories">💍 Accessories</a>
          <a href="/vault?category=perfumes">🌹 Perfumes</a>
        </div>
      <li><a href="/track" class="nav-link">Track Order</a></li>
    </ul>

    <div class="nav-actions">
      <!-- Theme Toggle — better sun/moon SVG icons -->
      <button class="nav-icon-btn theme-toggle" id="themeToggle" title="Toggle theme" aria-label="Toggle dark/light mode">
        <!-- Moon icon for dark mode -->
        <span class="theme-icon-dark">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </span>
        <!-- Sun icon for light mode -->
        <span class="theme-icon-light">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </span>
      </button>

      <!-- Wishlist -->
      <a href="/wishlist" class="nav-icon-btn" title="Wishlist">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </a>

      <!-- Cart -->
      <a href="/cart" class="nav-icon-btn cart-icon-btn" title="Cart">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <% if (cartCount > 0) { %>
          <span class="cart-badge"><%= cartCount %></span>
        <% } %>
      </a>

      <!-- Auth -->
      <% if (user) { %>
        <!-- Profile: click-based, not hover-lost -->
        <div class="nav-user-menu" id="profileDropdown">
          <button class="nav-user-btn" onclick="toggleDropdown('profileDropdown')" aria-expanded="false" aria-haspopup="true">
            <span class="nav-user-avatar"><%= user.name.charAt(0).toUpperCase() %></span>
            <span class="nav-user-name"><%= user.name.split(' ')[0] %></span>
            <svg class="dropdown-arrow" width="9" height="5" viewBox="0 0 10 6"><path d="M0 0l5 6 5-6z" fill="currentColor"/></svg>
          </button>
          <div class="nav-user-dropdown" id="profileMenu">
            <% if (isAdmin) { %><a href="/admin">⚙️ Admin Panel</a><% } %>
            <a href="/wishlist">❤️ My Wishlist</a>
            <a href="/track">📦 Track Order</a>
            <!-- Edit Profile -->
            <button class="dropdown-edit-profile" onclick="openProfileModal()">✏️ Edit Profile</button>
            <div class="dropdown-divider"></div>
            <form action="/logout" method="POST" style="margin:0">
              <button type="submit" class="dropdown-logout">🚪 Sign Out</button>
            </form>
          </div>
        </div>
      <% } else { %>
        <a href="/login" class="btn-nav-login">Sign In</a>
        <a href="/register" class="btn-nav-register">Join</a>
      <% } %>

      <button class="nav-mobile-toggle" id="mobileToggle" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="/" class="mobile-link" id="homeMobileLink">Home</a>
    <div class="mobile-section-label">Collections</div>
    <a href="/vault?category=dream" class="mobile-link mobile-sub">👑 Dream Abayas</a>
    <a href="/vault?category=modest" class="mobile-link mobile-sub">🌸 Modest & Beautiful</a>
    <a href="/vault?category=aesthetic" class="mobile-link mobile-sub">🤍 Simply Aesthetic</a>
    <a href="/vault?category=hijabs" class="mobile-link mobile-sub">🕌 Hijabs & Niqabs</a>
    <a href="/vault?category=accessories" class="mobile-link mobile-sub">💍 Accessories</a>
    <a href="/vault?category=perfumes" class="mobile-link mobile-sub">🌹 Perfumes</a>
    <a href="/wishlist" class="mobile-link">❤️ Wishlist</a>
    <a href="/cart" class="mobile-link">🛍️ Cart (<%= cartCount %>)</a>
    <a href="/track" class="mobile-link">📦 Track Order</a>
    <% if (user) { %>
      <% if (isAdmin) { %><a href="/admin" class="mobile-link">⚙️ Admin</a><% } %>
      <button class="mobile-link" onclick="openProfileModal()">✏️ Edit Profile</button>
      <form action="/logout" method="POST"><button class="mobile-link mobile-logout">🚪 Sign Out</button></form>
    <% } else { %>
      <a href="/login" class="mobile-link">Sign In</a>
      <a href="/register" class="mobile-link mobile-register">✦ Join The Palace</a>
    <% } %>
  </div>
</nav>

<!-- ══ PROFILE EDIT MODAL ════════════════════════════════════ -->
<% if (user) { %>
<div id="profileModalOverlay" class="profile-modal-overlay" onclick="if(event.target===this) closeProfileModal()">
  <div class="profile-modal" role="dialog" aria-label="Edit Profile">
    <button class="profile-modal-close" onclick="closeProfileModal()">✕</button>
    <div class="profile-modal-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
    <h3 class="profile-modal-title">Edit Profile</h3>
    <p class="profile-modal-sub">Update your name or change your password</p>

    <div id="profileError"   class="profile-msg profile-error"   style="display:none"></div>
    <div id="profileSuccess" class="profile-msg profile-success" style="display:none"></div>

    <div class="profile-modal-section">
      <label>Display Name</label>
      <input type="text" id="profileName" class="auth-input" value="<%= user.name %>" maxlength="100" placeholder="Your name"/>
    </div>

    <div class="profile-modal-divider">— Change Password —</div>

    <div class="profile-modal-section">
      <label>Current Password</label>
      <input type="password" id="currentPw" class="auth-input" placeholder="Current password" maxlength="128"/>
    </div>
    <div class="profile-modal-section">
      <label>New Password</label>
      <input type="password" id="newPw" class="auth-input" placeholder="Min. 8 characters" maxlength="128"/>
      <div class="password-strength" style="margin-top:6px">
        <div class="pw-bar" id="profilePwBar" style="width:0"></div>
        <span class="pw-label" id="profilePwLabel"></span>
      </div>
    </div>

    <button class="btn-royal full-width" onclick="saveProfile()" id="saveProfileBtn">✦ Save Changes</button>
  </div>
</div>
<% } %>
