<!-- ══ CART DRAWER ════════════════════════════════════════════ -->
<div id="cartDrawerOverlay" class="cart-drawer-overlay"></div>
<aside id="cartDrawer" class="cart-drawer">
  <div class="cart-drawer-header">
    <h3>Your Cart (<span id="drawerCartCount"><%= cartCount %></span>)</h3>
    <button id="closeCartDrawer" class="cart-drawer-close">✕</button>
  </div>
  <div class="cart-drawer-body" id="cartDrawerBody">
    <p class="cart-drawer-empty">Your cart is empty. Let the palace fill it.</p>
  </div>
  <div class="cart-drawer-footer">
    <a href="/cart" class="btn-royal full-width">View Full Cart</a>
  </div>
</aside>
